# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=rental"

# Session
SESSION_SECRET="replace-with-a-long-random-string-at-least-64-characters"

# App
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"

# Admin login URL segment — obscures the login page from casual discovery
ADMIN_PATH="/admin"

# AWS SES (email sending)
SES_SMTP_HOST="email-smtp.eu-west-1.amazonaws.com"
SES_SMTP_PORT=587
SES_SMTP_USER="your-ses-smtp-username"
SES_SMTP_PASS="your-ses-smtp-password"
SES_FROM_ADDRESS="info@yourdomain.ie"
SES_FROM_NAME="Your Business Name"

# Manager notification email — where new enquiry alerts are sent
MANAGER_NOTIFICATION_EMAIL="manager@yourdomain.ie"

# Google Maps Platform
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# API cost protection — monthly budget in USD before in-app warning fires
API_MONTHLY_BUDGET_USD=50

# File uploads
UPLOAD_MAX_SIZE_MB=10
