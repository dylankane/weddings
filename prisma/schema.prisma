generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["rental"]
}

// ─── Users & Access ────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs              AuditLog[]
  apiUsageLogs           ApiUsageLog[]
  jobsCreated            Job[]           @relation("JobCreatedBy")
  companySettingsUpdates CompanySettings[]

  @@map("users")
  @@schema("rental")
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  CLIENT

  @@schema("rental")
}

// ─── Audit & Usage Logs ────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@schema("rental")
}

model ApiUsageLog {
  id          Int        @id @default(autoincrement())
  apiName     ApiName    @map("api_name")
  triggeredBy ApiTrigger @map("triggered_by")
  userId      Int?       @map("user_id")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("api_usage_logs")
  @@schema("rental")
}

enum ApiName {
  GEOCODING
  DISTANCE_MATRIX
  PLACES_TEXT_SEARCH

  @@schema("rental")
}

enum ApiTrigger {
  MANAGER_TOOL
  PUBLIC_CALCULATOR

  @@schema("rental")
}

// ─── Email & Settings ──────────────────────────────────────────────────────────

model EmailTemplate {
  id           Int               @id @default(autoincrement())
  name         String
  triggerEvent EmailTriggerEvent @unique @map("trigger_event")
  subject      String
  body         String?
  description  String
  isActive     Boolean           @default(true) @map("is_active")

  @@map("email_templates")
  @@schema("rental")
}

enum EmailTriggerEvent {
  ENQUIRY_SUBMITTED_CUSTOMER
  ENQUIRY_SUBMITTED_MANAGER
  QUOTE_SENT
  INVOICE_SENT

  @@schema("rental")
}

model CompanySettings {
  id                Int      @id @default(autoincrement())
  companyName       String   @map("company_name")
  tagline           String?
  logoLightSmallUrl String?  @map("logo_light_small_url")
  logoLightLargeUrl String?  @map("logo_light_large_url")
  logoDarkSmallUrl  String?  @map("logo_dark_small_url")
  logoDarkLargeUrl  String?  @map("logo_dark_large_url")
  contactEmail      String   @map("contact_email")
  contactPhone      String   @map("contact_phone")
  contactAddress    String   @map("contact_address")
  socialLinks       Json?    @map("social_links")
  metaTitle         String?  @map("meta_title")
  metaDescription   String?  @map("meta_description")
  deliveryInfoText      String?  @map("delivery_info_text")
  deliveryFreeZoneLabel String?  @map("delivery_free_zone_label")
  emailSignOff          String?  @map("email_sign_off")
  businessLat       Decimal? @map("business_lat")
  businessLng       Decimal? @map("business_lng")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedById       Int?     @map("updated_by_id")

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("company_settings")
  @@schema("rental")
}

// ─── Customers ─────────────────────────────────────────────────────────────────

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  jobs Job[]

  @@map("customers")
  @@schema("rental")
}

// ─── Products ──────────────────────────────────────────────────────────────────

model Product {
  id                    Int      @id @default(autoincrement())
  name                  String
  slug                  String   @unique
  description           String
  stockQuantity         Int      @map("stock_quantity")
  isCustomisable        Boolean  @default(false) @map("is_customisable")
  isActive              Boolean  @default(true) @map("is_active")
  displayOrder          Int      @default(0) @map("display_order")
  pricePerEvent         Decimal? @map("price_per_event") @db.Decimal(10, 2)
  pricePerDay           Decimal? @map("price_per_day")   @db.Decimal(10, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  images               ProductImage[]
  customisationOptions ProductCustomisationOption[]
  jobItems             JobItem[]
  blockedDates         JobItemDate[]

  @@map("products")
  @@schema("rental")
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  url          String
  altText      String?  @map("alt_text")
  displayOrder Int      @default(0) @map("display_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
  @@schema("rental")
}

model ProductCustomisationOption {
  id           Int                     @id @default(autoincrement())
  productId    Int                     @map("product_id")
  name         String
  description  String?
  type         CustomisationOptionType?
  options      Json?
  basePrice    Decimal?                @map("base_price") @db.Decimal(10, 2)
  isRequired   Boolean                 @default(false) @map("is_required")
  displayOrder Int                     @default(0) @map("display_order")
  isActive     Boolean                 @default(true) @map("is_active")

  product               Product               @relation(fields: [productId], references: [id])
  jobItemCustomisations JobItemCustomisation[]

  @@map("product_customisation_options")
  @@schema("rental")
}

enum CustomisationOptionType {
  TEXT
  SELECT
  BOOLEAN

  @@schema("rental")
}

// ─── Jobs ──────────────────────────────────────────────────────────────────────

model Job {
  id          Int       @id @default(autoincrement())
  customerId  Int       @map("customer_id")
  status      JobStatus @default(ENQUIRY)
  source      JobSource
  jobStart    DateTime? @map("job_start") @db.Date
  jobEnd      DateTime? @map("job_end") @db.Date
  notes       String?
  createdById Int       @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  customer  Customer  @relation(fields: [customerId], references: [id])
  createdBy User      @relation("JobCreatedBy", fields: [createdById], references: [id])
  items        JobItem[]
  blockedDates JobItemDate[]
  delivery     Delivery?
  pricing      Pricing?
  quote        Quote?
  invoice      Invoice?

  @@map("jobs")
  @@schema("rental")
}

enum JobStatus {
  ENQUIRY
  CONFIRMED
  COMPLETED
  CANCELLED

  @@schema("rental")
}

enum JobSource {
  CUSTOMER_FORM
  MANAGER_CREATED

  @@schema("rental")
}

model JobItem {
  id        Int      @id @default(autoincrement())
  jobId     Int      @map("job_id")
  productId Int      @map("product_id")
  unitPrice             Decimal? @map("unit_price") @db.Decimal(10, 2)
  notes                 String?
  customisationCheck    Boolean? @map("customisation_check")

  job            Job                   @relation(fields: [jobId], references: [id])
  product        Product               @relation(fields: [productId], references: [id])
  customisations JobItemCustomisation[]
  blockedDates   JobItemDate[]

  @@map("job_items")
  @@schema("rental")
}

model JobItemCustomisation {
  id                    Int     @id @default(autoincrement())
  jobItemId             Int     @map("job_item_id")
  customisationOptionId Int?    @map("customisation_option_id")
  value                 String
  notes                 String?

  jobItem             JobItem                     @relation(fields: [jobItemId], references: [id])
  customisationOption ProductCustomisationOption? @relation(fields: [customisationOptionId], references: [id])

  @@map("job_item_customisations")
  @@schema("rental")
}

model JobItemDate {
  id        Int      @id @default(autoincrement())
  jobId     Int      @map("job_id")
  jobItemId Int      @map("job_item_id")
  productId Int      @map("product_id")
  date      DateTime @db.Date

  job     Job     @relation(fields: [jobId], references: [id])
  jobItem JobItem @relation(fields: [jobItemId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("job_item_dates")
  @@schema("rental")
}

// ─── Delivery ──────────────────────────────────────────────────────────────────

model Delivery {
  id             Int            @id @default(autoincrement())
  jobId          Int            @unique @map("job_id")
  outboundMethod DeliveryMethod @map("outbound_method")
  returnMethod   DeliveryMethod @map("return_method")
  venueName      String?        @map("venue_name")
  venueAddress   String?        @map("venue_address")
  venueEircode   String?        @map("venue_eircode")
  venueCounty    String?        @map("venue_county")
  lat              Decimal?
  lng              Decimal?
  distanceKm       Decimal?       @map("distance_km")
  durationMins     Int?           @map("duration_mins")
  mapsUrl          String?        @map("maps_url")
  suggestedPrice   Decimal?       @db.Decimal(10, 2) @map("suggested_price")
  calculatorResult String?        @map("calculator_result")
  notes            String?
  outboundAt     DateTime?      @map("outbound_at")
  returnAt       DateTime?      @map("return_at")

  job Job @relation(fields: [jobId], references: [id])

  @@map("deliveries")
  @@schema("rental")
}

enum DeliveryMethod {
  STAFF
  CUSTOMER

  @@schema("rental")
}

// ─── Pricing ───────────────────────────────────────────────────────────────────

model Pricing {
  id             Int      @id @default(autoincrement())
  jobId          Int      @unique @map("job_id")
  rentalCost     Decimal  @map("rental_cost") @db.Decimal(10, 2)
  deliveryCost   Decimal  @map("delivery_cost") @db.Decimal(10, 2)
  totalCost      Decimal  @map("total_cost") @db.Decimal(10, 2)
  deliveryZoneId Int?     @map("delivery_zone_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  job          Job           @relation(fields: [jobId], references: [id])
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id], onDelete: SetNull)

  @@map("pricing")
  @@schema("rental")
}

// ─── Quotes ────────────────────────────────────────────────────────────────────

model Quote {
  id        Int       @id @default(autoincrement())
  jobId     Int       @unique @map("job_id")
  pdfUrl    String    @map("pdf_url")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id])

  @@map("quotes")
  @@schema("rental")
}

// ─── Invoices ──────────────────────────────────────────────────────────────────

model Invoice {
  id        Int           @id @default(autoincrement())
  jobId     Int           @unique @map("job_id")
  reference String        @unique
  status    InvoiceStatus @default(DRAFT)
  dueDate   DateTime?     @map("due_date") @db.Date
  pdfUrl    String?       @map("pdf_url")
  sentAt    DateTime?     @map("sent_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  job Job @relation(fields: [jobId], references: [id])

  @@map("invoices")
  @@schema("rental")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE

  @@schema("rental")
}

// ─── Delivery Zones ────────────────────────────────────────────────────────────

model DeliveryZone {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  minKm        Decimal? @map("min_km")
  maxKm        Decimal? @map("max_km")
  price        Decimal? @db.Decimal(10, 2)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")

  pricings Pricing[]

  @@map("delivery_zones")
  @@schema("rental")
}
