generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["rental"]
}

// ─── Users & Access ────────────────────────────────────────────────────────────

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  role         UserRole @default(MANAGER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  auditLogs              AuditLog[]
  apiUsageLogs           ApiUsageLog[]
  bookingsCreated        Booking[]       @relation("BookingCreatedBy")
  quotesCreated          Quote[]
  invoicesCreated        Invoice[]
  companySettingsUpdates CompanySettings[]

  @@map("users")
  @@schema("rental")
}

enum UserRole {
  SUPER_ADMIN
  MANAGER
  CLIENT

  @@schema("rental")
}

// ─── Audit & Usage Logs ────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   Int      @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@schema("rental")
}

model ApiUsageLog {
  id          Int        @id @default(autoincrement())
  apiName     ApiName    @map("api_name")
  triggeredBy ApiTrigger @map("triggered_by")
  userId      Int?       @map("user_id")
  createdAt   DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("api_usage_logs")
  @@schema("rental")
}

enum ApiName {
  GEOCODING
  DISTANCE_MATRIX
  PLACES_TEXT_SEARCH

  @@schema("rental")
}

enum ApiTrigger {
  MANAGER_TOOL
  PUBLIC_CALCULATOR

  @@schema("rental")
}

// ─── Email & Settings ──────────────────────────────────────────────────────────

model EmailTemplate {
  id           Int                @id @default(autoincrement())
  name         String
  triggerEvent EmailTriggerEvent  @unique @map("trigger_event")
  subject      String
  description  String
  isActive     Boolean            @default(true) @map("is_active")

  @@map("email_templates")
  @@schema("rental")
}

enum EmailTriggerEvent {
  ENQUIRY_SUBMITTED_CUSTOMER
  ENQUIRY_SUBMITTED_MANAGER
  QUOTE_SENT
  INVOICE_SENT

  @@schema("rental")
}

model CompanySettings {
  id               Int      @id @default(autoincrement())
  companyName      String   @map("company_name")
  tagline          String?
  logoLightSmallUrl String? @map("logo_light_small_url")
  logoLightLargeUrl String? @map("logo_light_large_url")
  logoDarkSmallUrl  String? @map("logo_dark_small_url")
  logoDarkLargeUrl  String? @map("logo_dark_large_url")
  contactEmail     String   @map("contact_email")
  contactPhone     String   @map("contact_phone")
  contactAddress   String   @map("contact_address")
  socialLinks      Json?    @map("social_links")
  metaTitle        String?  @map("meta_title")
  metaDescription  String?  @map("meta_description")
  deliveryInfoText String?  @map("delivery_info_text")
  businessLat      Decimal? @map("business_lat")
  businessLng      Decimal? @map("business_lng")
  updatedAt        DateTime @updatedAt @map("updated_at")
  updatedById      Int?     @map("updated_by_id")

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("company_settings")
  @@schema("rental")
}

// ─── Customers ─────────────────────────────────────────────────────────────────

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String?
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  enquiries Enquiry[]
  bookings  Booking[]

  @@map("customers")
  @@schema("rental")
}

// ─── Products ──────────────────────────────────────────────────────────────────

model Product {
  id                    Int      @id @default(autoincrement())
  name                  String
  slug                  String   @unique
  description           String
  stockQuantity         Int      @map("stock_quantity")
  isCustomisable        Boolean  @default(false) @map("is_customisable")
  customisationOverview String?  @map("customisation_overview")
  isActive              Boolean  @default(true) @map("is_active")
  displayOrder          Int      @default(0) @map("display_order")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  images               ProductImage[]
  customisationOptions ProductCustomisationOption[]
  enquiryItems         EnquiryItem[]
  bookingItems         BookingItem[]

  @@map("products")
  @@schema("rental")
}

model ProductImage {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  url          String
  altText      String?  @map("alt_text")
  displayOrder Int      @default(0) @map("display_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@map("product_images")
  @@schema("rental")
}

model ProductCustomisationOption {
  id           Int                     @id @default(autoincrement())
  productId    Int                     @map("product_id")
  name         String
  description  String?
  type         CustomisationOptionType
  options      Json?
  basePrice    Decimal?                @map("base_price") @db.Decimal(10, 2)
  isRequired   Boolean                 @default(false) @map("is_required")
  displayOrder Int                     @default(0) @map("display_order")
  isActive     Boolean                 @default(true) @map("is_active")

  product                  Product                  @relation(fields: [productId], references: [id])
  bookingItemCustomisations BookingItemCustomisation[]

  @@map("product_customisation_options")
  @@schema("rental")
}

enum CustomisationOptionType {
  TEXT
  SELECT
  BOOLEAN

  @@schema("rental")
}

// ─── Enquiries ─────────────────────────────────────────────────────────────────

model Enquiry {
  id            Int           @id @default(autoincrement())
  customerId    Int?          @map("customer_id")
  source        EnquirySource
  status        EnquiryStatus @default(NEW)
  hireStartDate DateTime?     @map("hire_start_date") @db.Date
  hireEndDate   DateTime?     @map("hire_end_date") @db.Date
  venueName     String?       @map("venue_name")
  venueAddress  String?       @map("venue_address")
  venueEircode  String?       @map("venue_eircode")
  venueCounty   String?       @map("venue_county")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  customer Customer?    @relation(fields: [customerId], references: [id])
  items    EnquiryItem[]
  bookings Booking[]
  quotes   Quote[]

  @@map("enquiries")
  @@schema("rental")
}

enum EnquirySource {
  CUSTOMER_FORM
  MANAGER_CREATED

  @@schema("rental")
}

enum EnquiryStatus {
  NEW
  PENDING
  CONVERTED
  ARCHIVED

  @@schema("rental")
}

model EnquiryItem {
  id                 Int     @id @default(autoincrement())
  enquiryId          Int     @map("enquiry_id")
  productId          Int     @map("product_id")
  quantity           Int
  customisationNotes String? @map("customisation_notes")

  enquiry Enquiry @relation(fields: [enquiryId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("enquiry_items")
  @@schema("rental")
}

// ─── Bookings ──────────────────────────────────────────────────────────────────

model Booking {
  id                   Int             @id @default(autoincrement())
  enquiryId            Int?            @map("enquiry_id")
  customerId           Int             @map("customer_id")
  status               BookingStatus   @default(PROVISIONAL)
  provisionalExpiresAt DateTime?       @map("provisional_expires_at")
  hireStartDatetime    DateTime        @map("hire_start_datetime")
  hireEndDatetime      DateTime        @map("hire_end_datetime")
  fulfillmentType      FulfillmentType @map("fulfillment_type")
  deliveryAddress      String?         @map("delivery_address")
  deliveryDatetime     DateTime?       @map("delivery_datetime")
  collectionDatetime   DateTime?       @map("collection_datetime")
  deliveryZoneId       Int?            @map("delivery_zone_id")
  deliveryCost         Decimal?        @map("delivery_cost") @db.Decimal(10, 2)
  itemsDelivered       Boolean         @default(false) @map("items_delivered")
  itemsCollected       Boolean         @default(false) @map("items_collected")
  notes                String?
  createdById          Int             @map("created_by_id")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  enquiry      Enquiry?      @relation(fields: [enquiryId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  createdBy    User          @relation("BookingCreatedBy", fields: [createdById], references: [id])
  items        BookingItem[]
  invoices     Invoice[]

  @@map("bookings")
  @@schema("rental")
}

enum BookingStatus {
  PROVISIONAL
  CONFIRMED
  COMPLETED
  CANCELLED

  @@schema("rental")
}

enum FulfillmentType {
  CUSTOMER_COLLECTS
  STAFF_DELIVERS

  @@schema("rental")
}

model BookingItem {
  id          Int      @id @default(autoincrement())
  bookingId   Int      @map("booking_id")
  productId   Int      @map("product_id")
  quantity    Int
  quotedPrice Decimal? @map("quoted_price") @db.Decimal(10, 2)

  booking        Booking                  @relation(fields: [bookingId], references: [id])
  product        Product                  @relation(fields: [productId], references: [id])
  customisations BookingItemCustomisation[]

  @@map("booking_items")
  @@schema("rental")
}

model BookingItemCustomisation {
  id                    Int      @id @default(autoincrement())
  bookingItemId         Int      @map("booking_item_id")
  customisationOptionId Int      @map("customisation_option_id")
  value                 String
  agreedCost            Decimal? @map("agreed_cost") @db.Decimal(10, 2)
  notes                 String?

  bookingItem         BookingItem                @relation(fields: [bookingItemId], references: [id])
  customisationOption ProductCustomisationOption @relation(fields: [customisationOptionId], references: [id])

  @@map("booking_item_customisations")
  @@schema("rental")
}

// ─── Quotes ────────────────────────────────────────────────────────────────────

model Quote {
  id          Int         @id @default(autoincrement())
  enquiryId   Int         @map("enquiry_id")
  reference   String      @unique
  status      QuoteStatus @default(DRAFT)
  expiresAt   DateTime    @map("expires_at") @db.Date
  notes       String?
  sentAt      DateTime?   @map("sent_at")
  sentTo      String?     @map("sent_to")
  createdById Int         @map("created_by_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  enquiry   Enquiry     @relation(fields: [enquiryId], references: [id])
  createdBy User        @relation(fields: [createdById], references: [id])
  items     QuoteItem[]

  @@map("quotes")
  @@schema("rental")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED

  @@schema("rental")
}

model QuoteItem {
  id          Int     @id @default(autoincrement())
  quoteId     Int     @map("quote_id")
  description String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(10, 2)

  quote Quote @relation(fields: [quoteId], references: [id])

  @@map("quote_items")
  @@schema("rental")
}

// ─── Invoices ──────────────────────────────────────────────────────────────────

model Invoice {
  id          Int           @id @default(autoincrement())
  bookingId   Int           @map("booking_id")
  reference   String        @unique
  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime      @map("due_date") @db.Date
  notes       String?
  sentAt      DateTime?     @map("sent_at")
  sentTo      String?       @map("sent_to")
  createdById Int           @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  booking   Booking       @relation(fields: [bookingId], references: [id])
  createdBy User          @relation(fields: [createdById], references: [id])
  items     InvoiceItem[]

  @@map("invoices")
  @@schema("rental")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE

  @@schema("rental")
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoiceId   Int     @map("invoice_id")
  description String
  quantity    Int
  unitPrice   Decimal @map("unit_price") @db.Decimal(10, 2)
  lineTotal   Decimal @map("line_total") @db.Decimal(10, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@map("invoice_items")
  @@schema("rental")
}

// ─── Delivery Zones ────────────────────────────────────────────────────────────

model DeliveryZone {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  zoneType      ZoneType @map("zone_type")
  price         Decimal? @db.Decimal(10, 2)
  isEnquireOnly Boolean  @default(false) @map("is_enquire_only")
  displayOrder  Int      @default(0) @map("display_order")
  isActive      Boolean  @default(true) @map("is_active")
  centerLat     Decimal? @map("center_lat")
  centerLng     Decimal? @map("center_lng")
  radiusKm      Decimal? @map("radius_km")

  bookings Booking[]

  @@map("delivery_zones")
  @@schema("rental")
}

enum ZoneType {
  NAMED_REGION
  RADIUS

  @@schema("rental")
}
