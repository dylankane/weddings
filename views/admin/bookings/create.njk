{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/rental/bookings">← Bookings</a></p>
  <h1>New Booking</h1>
  {% if enquiry %}<p>From Enquiry #{{ enquiry.id }} — {{ enquiry.customer.name }}</p>{% endif %}

  <form method="POST" action="/admin/rental/bookings/create">
    {% if enquiry %}
      <input type="hidden" name="enquiryId" value="{{ enquiry.id }}">
      <input type="hidden" name="customerId" value="{{ enquiry.customer.id }}">
    {% else %}
      <div>
        <label>Customer *</label>
        <select name="customerId" required>
          <option value="">— Select customer —</option>
          {% for customer in customers %}
            <option value="{{ customer.id }}">{{ customer.name }} ({{ customer.email }})</option>
          {% endfor %}
        </select>
      </div>
    {% endif %}

    <div>
      <label>Status</label>
      <select name="status" required>
        <option value="PROVISIONAL">Provisional</option>
        <option value="CONFIRMED">Confirmed</option>
      </select>
    </div>
    <div>
      <label>Provisional Expires At</label>
      <input type="datetime-local" name="provisionalExpiresAt">
    </div>
    <div>
      <label>Hire Start *</label>
      <input type="datetime-local" name="hireStartDatetime" required>
    </div>
    <div>
      <label>Hire End *</label>
      <input type="datetime-local" name="hireEndDatetime" required>
    </div>
    <div>
      <label>Fulfillment Type *</label>
      <select name="fulfillmentType" required>
        <option value="CUSTOMER_COLLECTS">Customer Collects</option>
        <option value="STAFF_DELIVERS">Staff Delivers</option>
      </select>
    </div>
    <div>
      <label>Delivery Address</label>
      <input type="text" name="deliveryAddress">
    </div>
    <div>
      <label>Delivery Date/Time</label>
      <input type="datetime-local" name="deliveryDatetime">
    </div>
    <div>
      <label>Collection Date/Time</label>
      <input type="datetime-local" name="collectionDatetime">
    </div>
    <div>
      <label>Delivery Zone</label>
      <select name="deliveryZoneId">
        <option value="">— None —</option>
        {% for zone in deliveryZones %}
          <option value="{{ zone.id }}">{{ zone.name }}</option>
        {% endfor %}
      </select>
    </div>
    <div>
      <label>Delivery Cost (€)</label>
      <input type="number" step="0.01" name="deliveryCost">
    </div>
    <div>
      <label>Notes</label>
      <textarea name="notes"></textarea>
    </div>
    <button type="submit">Create Booking</button>
    <a href="/admin/rental/bookings">Cancel</a>
  </form>
{% endblock %}

