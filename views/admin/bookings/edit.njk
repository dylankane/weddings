{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/rental/bookings/{{ booking.id }}">← Booking #{{ booking.id }}</a></p>
  <h1>Edit Booking #{{ booking.id }}</h1>

  <form method="POST" action="/admin/rental/bookings/{{ booking.id }}/edit">
    <div>
      <label>Hire Start</label>
      <input type="datetime-local" name="hireStartDatetime" value="{{ booking.hireStartDatetime }}" required>
    </div>
    <div>
      <label>Hire End</label>
      <input type="datetime-local" name="hireEndDatetime" value="{{ booking.hireEndDatetime }}" required>
    </div>
    <div>
      <label>Fulfillment Type</label>
      <select name="fulfillmentType" required>
        <option value="CUSTOMER_COLLECTS" {% if booking.fulfillmentType == 'CUSTOMER_COLLECTS' %}selected{% endif %}>Customer Collects</option>
        <option value="STAFF_DELIVERS" {% if booking.fulfillmentType == 'STAFF_DELIVERS' %}selected{% endif %}>Staff Delivers</option>
      </select>
    </div>
    <div>
      <label>Delivery Address</label>
      <input type="text" name="deliveryAddress" value="{{ booking.deliveryAddress }}">
    </div>
    <div>
      <label>Delivery Date/Time</label>
      <input type="datetime-local" name="deliveryDatetime" value="{{ booking.deliveryDatetime }}">
    </div>
    <div>
      <label>Collection Date/Time</label>
      <input type="datetime-local" name="collectionDatetime" value="{{ booking.collectionDatetime }}">
    </div>
    <div>
      <label>Delivery Zone</label>
      <select name="deliveryZoneId">
        <option value="">— None —</option>
        {% for zone in deliveryZones %}
          <option value="{{ zone.id }}" {% if booking.deliveryZoneId == zone.id %}selected{% endif %}>{{ zone.name }}</option>
        {% endfor %}
      </select>
    </div>
    <div>
      <label>Delivery Cost (€)</label>
      <input type="number" step="0.01" name="deliveryCost" value="{{ booking.deliveryCost }}">
    </div>
    <div>
      <label>Provisional Expires At</label>
      <input type="datetime-local" name="provisionalExpiresAt" value="{{ booking.provisionalExpiresAt }}">
    </div>
    <div>
      <label>Notes</label>
      <textarea name="notes">{{ booking.notes }}</textarea>
    </div>
    <button type="submit">Save Changes</button>
    <a href="/admin/rental/bookings/{{ booking.id }}">Cancel</a>
  </form>
{% endblock %}

