{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/settings?tab=delivery">← Settings / Delivery</a></p>
  <h1>Edit — {{ zone.name }}</h1>

  <form method="POST" action="/admin/rental/delivery-zones/{{ zone.id }}/edit">
    <div>
      <label>Zone Name *</label>
      <input type="text" name="name" value="{{ zone.name }}" required>
    </div>
    <div>
      <label>Description</label>
      <textarea name="description">{{ zone.description }}</textarea>
    </div>
    <div>
      <label>Zone Type *</label>
      <select name="zoneType" required>
        <option value="NAMED_REGION" {% if zone.zoneType == 'NAMED_REGION' %}selected{% endif %}>Named Region</option>
        <option value="RADIUS" {% if zone.zoneType == 'RADIUS' %}selected{% endif %}>Radius from Business</option>
      </select>
    </div>
    <div>
      <label>Price (€)</label>
      <input type="number" step="0.01" name="price" value="{{ zone.price }}">
    </div>
    <div>
      <label>Enquire Only</label>
      <input type="checkbox" name="isEnquireOnly" {% if zone.isEnquireOnly %}checked{% endif %}>
    </div>
    <div>
      <label>Display Order</label>
      <input type="number" name="displayOrder" value="{{ zone.displayOrder }}">
    </div>
    <div>
      <label>Centre Latitude</label>
      <input type="number" step="any" name="centerLat" value="{{ zone.centerLat }}">
    </div>
    <div>
      <label>Centre Longitude</label>
      <input type="number" step="any" name="centerLng" value="{{ zone.centerLng }}">
    </div>
    <div>
      <label>Radius (km)</label>
      <input type="number" step="0.1" name="radiusKm" value="{{ zone.radiusKm }}">
    </div>
    <button type="submit">Save Changes</button>
    <a href="/admin/settings?tab=delivery">Cancel</a>
  </form>

  {% if zone.isActive %}
    <h2>Deactivate</h2>
    <form method="POST" action="/admin/rental/delivery-zones/{{ zone.id }}/deactivate">
      <button type="submit">Deactivate Zone</button>
    </form>
  {% endif %}
{% endblock %}

