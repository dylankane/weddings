{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/rental/enquiries/{{ enquiry.id }}">← Enquiry #{{ enquiry.id }}</a></p>
  <h1>Create Quote for {{ enquiry.customer.name }}</h1>

  <form method="POST" action="/admin/rental/quotes/create">
    <input type="hidden" name="enquiryId" value="{{ enquiry.id }}">

    <div>
      <label>Expires On *</label>
      <input type="date" name="expiresAt" required>
    </div>
    <div>
      <label>Internal Notes</label>
      <textarea name="notes" rows="3"></textarea>
    </div>

    <h2>Line Items</h2>
    <p>Pre-filled from enquiry items. Edit as needed.</p>

    <table>
      <thead>
        <tr><th>Description</th><th>Qty</th><th>Unit Price (€)</th><th></th></tr>
      </thead>
      <tbody id="line-items-body">
        {% for item in enquiry.items %}
          <tr>
            <td><input type="text" name="line[description]" value="{{ item.product.name }}" required></td>
            <td><input type="number" name="line[quantity]" value="{{ item.quantity }}" min="1" required></td>
            <td><input type="number" name="line[unitPrice]" step="0.01" required></td>
            <td><button type="button" onclick="this.closest('tr').remove()">Remove</button></td>
          </tr>
        {% endfor %}
      </tbody>
    </table>

    <button type="button" id="add-line-item">Add Line</button>

    <br>
    <button type="submit">Create Quote</button>
    <a href="/admin/rental/enquiries/{{ enquiry.id }}">Cancel</a>
  </form>
{% endblock %}

{% block scripts %}
  <script src="/js/quote-editor.js"></script>
{% endblock %}

