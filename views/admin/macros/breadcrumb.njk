{% macro breadcrumb(crumbs) %}
  <nav aria-label="Breadcrumb">
    {% for crumb in crumbs %}
      {% if crumb.url and not loop.last %}
        <a href="{{ crumb.url }}">{{ crumb.label }}</a> /
      {% else %}
        <span {% if loop.last %}aria-current="page"{% endif %}>{{ crumb.label }}</span>
      {% endif %}
    {% endfor %}
  </nav>
{% endmacro %}
