{% macro confirmModal(id, title, message, action, method, buttonLabel, buttonClass) %}
  <dialog id="{{ id }}">
    <form method="{{ method or 'POST' }}" action="{{ action }}">
      <h2>{{ title }}</h2>
      <p>{{ message }}</p>
      <button type="button" onclick="document.getElementById('{{ id }}').close()">Cancel</button>
      <button type="submit">{{ buttonLabel or 'Confirm' }}</button>
    </form>
  </dialog>
{% endmacro %}
