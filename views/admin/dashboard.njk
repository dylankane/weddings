{% extends "admin/layout.njk" %}
{% from "admin/macros/breadcrumb.njk" import breadcrumb %}

{% block styles %}
<link rel="stylesheet" href="/css/admin/dashboard.css">
{% endblock %}

{% block content %}

{# ─── Page Bar ────────────────────────────────────────────────── #}

<div class="page-bar">
  {{ breadcrumb([{ label: 'Home' }]) }}
  <div class="page-bar-right">
    <p class="page-date">{{ formattedDate }}</p>
  </div>
</div>


<h1 class="page-greeting">{{ greeting }}, {{ sessionUser.displayName if sessionUser else 'there' }}.</h1>

{# ─── Sections ────────────────────────────────────────────────── #}

<div class="content-container">

{# ─── Two-Week Calendar ────────────────────────────────────────── #}

<section class="dash-section" aria-labelledby="calendar-title">
  <div class="data-card">
    <div class="cal-wrap">
      <div class="cal-grid" role="grid" aria-label="Two week calendar">
        {% for day in calendarDays %}
        <div class="cal-day{{ ' cal-day--today' if day.isToday }}" role="gridcell">
          <span class="cal-day-name">{{ day.dayName }}</span>
          <span class="cal-day-num">
            {{ day.dayNum }}{% if day.isFirstOfMonth %} {{ day.monthName }}{% endif %}
          </span>
          {% for job in day.jobs %}
            <a
              href="/admin/jobs?id={{ job.id }}"
              class="cal-event{{ ' cal-event--enquiry' if job.status === 'ENQUIRY' }}"
              title="{{ job.customer.name }}"
            >{{ job.customer.name }}</a>
          {% endfor %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{# ─── New Enquiries ────────────────────────────────────────────── #}

<section class="dash-section" aria-labelledby="enquiries-title">
  <div class="card-head">
    <h2 class="card-title" id="enquiries-title">New Enquiries</h2>
  </div>
  <div class="data-card">
    {% if enquiries | length %}
    <div class="table-wrap">
      <table class="data-table" aria-label="New enquiries">
        <thead>
          <tr>
            <th scope="col">Customer</th>
            <th scope="col">Product</th>
            <th scope="col">Wedding Date</th>
            <th scope="col">Source</th>
          </tr>
        </thead>
        <tbody>
          {% for job in enquiries %}
          <tr class="data-row" data-href="/admin/jobs?id={{ job.id }}">
            <td>
              <span class="dot dot--enquiry" aria-hidden="true"></span>
              {{ job.customer.name }}
            </td>
            <td>
              {% if job.items and job.items.length %}
                {{ job.items[0].product.name }}
              {% else %}
                <span style="color: var(--c-text-3)">—</span>
              {% endif %}
            </td>
            <td>
              <span class="date-main">{{ job.jobStart | dateFormat('short') if job.jobStart else '—' }}</span>
              {% if job.jobEnd %}
                <span class="date-sub">{{ job.jobEnd | dateFormat('short') }}</span>
              {% endif %}
            </td>
            <td>
              {{ 'Website' if job.source === 'CUSTOMER_FORM' else 'Manager' }}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div class="empty">No new enquiries</div>
    {% endif %}
  </div>
</section>

{# ─── Confirmed Bookings ───────────────────────────────────────── #}

<section class="dash-section" aria-labelledby="confirmed-title">
  <div class="card-head">
    <h2 class="card-title" id="confirmed-title">Confirmed Bookings</h2>
  </div>
  <div class="data-card">
    {% if confirmedJobs | length %}
    <div class="table-wrap">
      <table class="data-table" aria-label="Confirmed bookings">
        <thead>
          <tr>
            <th scope="col">Customer</th>
            <th scope="col">Venue</th>
            <th scope="col">Wedding Date</th>
            <th scope="col">Delivery</th>
            <th scope="col">Price</th>
          </tr>
        </thead>
        <tbody>
          {% for job in confirmedJobs %}
          <tr class="data-row" data-href="/admin/jobs?id={{ job.id }}">
            <td>
              <span class="dot dot--confirmed" aria-hidden="true"></span>
              {{ job.customer.name }}
            </td>
            <td>
              {{ job.delivery.venueName if job.delivery and job.delivery.venueName else '—' }}
            </td>
            <td>
              <span class="date-main">{{ job.jobStart | dateFormat('short') if job.jobStart else '—' }}</span>
              {% if job.jobEnd %}
                <span class="date-sub">{{ job.jobEnd | dateFormat('short') }}</span>
              {% endif %}
            </td>
            <td>
              {% if job.delivery %}
                <span class="date-main">{{ 'Staff' if job.delivery.outboundMethod === 'STAFF' else 'Customer' }}</span>
                {% if job.delivery.outboundMethod !== job.delivery.returnMethod %}
                  <span class="date-sub">{{ 'Staff' if job.delivery.returnMethod === 'STAFF' else 'Customer' }}</span>
                {% endif %}
              {% else %}
                —
              {% endif %}
            </td>
            <td>
              {{ job.pricing.totalCost | currency if job.pricing else '—' }}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
    {% else %}
    <div class="empty">No confirmed bookings</div>
    {% endif %}
  </div>
</section>

</div>

{% endblock %}
