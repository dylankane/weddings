{% extends "admin/base/layout.njk" %}
{% from "admin/macros/confirm-modal.njk" import confirmModal %}
{% from "admin/macros/audit-entry.njk" import auditEntry %}

{% block content %}
  <p><a href="/admin/rental/products">← Products</a></p>

  <h1>{{ product.name }}</h1>
  <p>Status: {{ 'Active' if product.isActive else 'Inactive' }}</p>

  <p>
    <a href="/admin/rental/products/{{ product.id }}/edit">Edit</a>
    {% if product.isActive %}
      | <button onclick="document.getElementById('deactivate-modal').showModal()">Deactivate</button>
    {% endif %}
  </p>

  <h2>Details</h2>
  <p>Slug: {{ product.slug }}</p>
  <p>Stock: {{ product.stockQuantity }}</p>
  <p>Display order: {{ product.displayOrder }}</p>

  <h2>Description</h2>
  <p>{{ product.description }}</p>

  {% if product.isCustomisable %}
    <h2>Customisation</h2>
    <p>{{ product.customisationOverview }}</p>
    {% if product.customisationOptions.length %}
      <ul>
        {% for option in product.customisationOptions %}
          <li>
            {{ option.name }} — {{ option.type }}
            {% if option.isRequired %} — Required{% endif %}
            {% if option.basePrice %} — +{{ option.basePrice | currency }}{% endif %}
            {% if option.type == 'SELECT' and option.options %} — Options: {{ option.options | join(', ') }}{% endif %}
          </li>
        {% endfor %}
      </ul>
    {% endif %}
  {% endif %}

  <h2>Images</h2>
  {% if product.images.length %}
    <ul>
      {% for image in product.images %}
        <li>
          <img src="{{ image.url }}" alt="{{ image.altText or '' }}" style="max-width:200px">
          {% if image.isPrimary %} — Primary{% endif %}
          | <form method="POST" action="/admin/rental/products/{{ product.id }}/images/{{ image.id }}/primary" style="display:inline">
              <button type="submit">Set Primary</button>
            </form>
          | <form method="POST" action="/admin/rental/products/{{ product.id }}/images/{{ image.id }}/delete" style="display:inline">
              <button type="submit">Remove</button>
            </form>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No images uploaded.</p>
  {% endif %}

  <h3>Upload Image</h3>
  <form method="POST" action="/admin/rental/products/{{ product.id }}/images/upload" enctype="multipart/form-data">
    <div>
      <label>Image file</label>
      <input type="file" name="file" accept="image/*">
    </div>
    <div>
      <label>Alt text</label>
      <input type="text" name="altText">
    </div>
    <button type="submit">Upload</button>
  </form>

  <h2>History</h2>
  {% if auditLogs.length %}
    <ul>{% for log in auditLogs %}{{ auditEntry(log) }}{% endfor %}</ul>
  {% else %}
    <p>No history yet.</p>
  {% endif %}

  {{ confirmModal('deactivate-modal', 'Deactivate Product', 'This product will be hidden from the public site.', '/admin/rental/products/' + product.id + '/deactivate', 'POST', 'Deactivate') }}
{% endblock %}

