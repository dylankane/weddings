{% extends "admin/layout.njk" %}
{% from "admin/macros/breadcrumb.njk" import breadcrumb %}

{% block styles %}
<link rel="stylesheet" href="/css/admin/products.css">
{% endblock %}

{% block content %}

{# ─── Page Bar ────────────────────────────────────────────────── #}

<div class="page-bar">
  {{ breadcrumb([
    { label: 'Home', url: '/admin' },
    { label: 'Products' }
  ]) }}
  <div class="page-bar-right">
    <a href="/admin/products/new" class="btn btn-pill--accent fw-heavy">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-add"/></svg>
      New product
    </a>
  </div>
</div>

<h1 class="page-greeting">All Products</h1>

{# ─── Error ───────────────────────────────────────────────────── #}

{% if error == 'in-use' %}
<p class="product-error">This product is used in existing jobs and cannot be deleted.</p>
{% endif %}

{# ─── Product List ────────────────────────────────────────────── #}

  {% if products.length %}
  <div class="item-list">
    {% for product in products %}

      {# Resolve primary image #}
      {% set primaryImg = null %}
      {% for img in product.images %}
        {% if img.isPrimary and not primaryImg %}{% set primaryImg = img %}{% endif %}
      {% endfor %}
      {% if not primaryImg and product.images.length %}
        {% set primaryImg = product.images[0] %}
      {% endif %}

      {# ── Row ── #}
      <div class="item-object js-product-row"
           aria-expanded="false"
           aria-controls="pd-{{ product.id }}">
        <div class="item-header">
          {% if primaryImg %}
            <img class="item-cover-thumb" src="{{ primaryImg.url }}" alt="{{ primaryImg.altText or product.name }}" loading="lazy">
          {% else %}
            <div class="item-cover-thumb item-cover-thumb--empty" aria-hidden="true"></div>
          {% endif %}
          <div class="item-header-text">
            <span class="item-ref">Product #{{ product.id }}</span>
            <div class="item-title-row">
              <h1 class="item-name">{{ product.name }}</h1>
              <label class="toggle-switch js-product-active" data-id="{{ product.id }}" aria-label="Toggle active">
                <input type="checkbox" {{ 'checked' if product.isActive }}>
                <span class="toggle-track"></span>
                <span class="toggle-label">Active</span>
              </label>
            </div>
          </div>
        </div>
        <div class="item-recap">
          {% if product.pricePerEvent %}<div class="recap-item">{{ product.pricePerEvent | currency }} / event</div>{% endif %}
          {% if product.pricePerDay %}<div class="recap-item">{{ product.pricePerDay | currency }} / day</div>{% endif %}
          <div class="recap-item">Stock {{ product.stockQuantity }}</div>
          {% if product.customisationOptions.length %}<div class="recap-item">Customisable</div>{% endif %}
        </div>
        <section class="form-section js-product-section">
          <div class="form-section-head js-detail-trigger">
            <h2 class="form-section-title">Details</h2>
            <svg class="btn-svg item-chevron" aria-hidden="true"><use href="#icon-chevron-down"/></svg>
          </div>

          <div class="form-section-view">

            <div class="form-group">
              <span class="field-label">Images</span>
              <div class="item-images">
                {% if product.images.length %}
                  {% for img in product.images %}
                    <img class="item-thumb js-lightbox-thumb"
                         src="{{ img.url }}"
                         alt="{{ img.altText or product.name }}"
                         loading="lazy">
                  {% endfor %}
                {% else %}
                  <div class="item-thumb item-thumb--empty" aria-hidden="true"></div>
                {% endif %}
              </div>
            </div>

            <div class="form-group">
              <span class="field-label">Description</span>
              <span class="field-value">{{ product.description }}</span>
            </div>

            {% if product.customisationOptions.length %}
              <section class="form-section form-section--nested">
                <div class="form-section-head">
                  <h2 class="form-section-title">Customisations</h2>
                  <label class="toggle-switch js-product-customisable" data-id="{{ product.id }}" aria-label="Toggle customisations">
                    <input type="checkbox" {{ 'checked' if product.isCustomisable }}>
                    <span class="toggle-track"></span>
                    <span class="toggle-label">Active</span>
                  </label>
                </div>
                <div class="form-section-view">
                  {% for opt in product.customisationOptions %}
                    <div class="form-row">
                      <div class="form-group">
                        <span class="field-label">Name</span>
                        <span class="field-value">{{ opt.name }}</span>
                      </div>
                      {% if opt.description %}
                      <div class="form-group">
                        <span class="field-label">Description</span>
                        <span class="field-value">{{ opt.description }}</span>
                      </div>
                      {% endif %}
                      {% if opt.basePrice %}
                      <div class="form-group">
                        <span class="field-label">Price</span>
                        <span class="field-value">{{ opt.basePrice | currency }}</span>
                      </div>
                      {% endif %}
                    </div>
                  {% endfor %}
                </div>
              </section>
            {% endif %}

            <div class="section-actions">
              <form action="/admin/products/{{ product.id }}/delete" method="POST" class="js-delete-form">
                <button type="submit" class="btn btn-delete">
                  <svg class="btn-svg" aria-hidden="true"><use href="#icon-delete"/></svg>
                  Delete
                </button>
              </form>
              <button type="button" class="btn btn-save" onclick="location.href='/admin/products/{{ product.id }}/edit'">
                <svg class="btn-svg" aria-hidden="true"><use href="#icon-edit"/></svg>
                Edit
              </button>
            </div>

          </div>
        </section>
      </div>

    {% endfor %}
  </div>
  {% else %}
    <div class="empty">No products yet</div>
  {% endif %}

{# ─── Lightbox ────────────────────────────────────────────────── #}

<div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image preview" aria-hidden="true">
  <button class="btn lightbox-close" id="lightbox-close" aria-label="Close">
    <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
  </button>
  <img class="lightbox-img" id="lightbox-img" src="" alt="">
</div>

{% endblock %}

{% block scripts %}
<script src="/js/admin/products.js"></script>
{% endblock %}
