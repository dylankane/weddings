{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/rental/products">← Products</a></p>
  <h1>New Product</h1>

  <form method="POST" action="/admin/rental/products/create">
    <div>
      <label>Name *</label>
      <input type="text" name="name" required>
    </div>
    <div>
      <label>Description *</label>
      <textarea name="description" required></textarea>
    </div>
    <div>
      <label>Stock Quantity *</label>
      <input type="number" name="stockQuantity" value="1" required>
    </div>
    <div>
      <label>Display Order</label>
      <input type="number" name="displayOrder" value="0">
    </div>
    <div>
      <label>Is Customisable</label>
      <input type="checkbox" name="isCustomisable">
    </div>
    <div>
      <label>Customisation Overview</label>
      <textarea name="customisationOverview"></textarea>
    </div>
    <button type="submit">Create Product</button>
    <a href="/admin/rental/products">Cancel</a>
  </form>
{% endblock %}

