{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/rental/enquiries">← Enquiries</a></p>
  <h1>New Enquiry</h1>

  <form method="POST" action="/admin/rental/enquiries/create">
    <h2>Customer</h2>
    <div>
      <label>Name *</label>
      <input type="text" name="customerName" required>
    </div>
    <div>
      <label>Email *</label>
      <input type="email" name="customerEmail" required>
    </div>
    <div>
      <label>Phone</label>
      <input type="tel" name="customerPhone">
    </div>

    <h2>Event Details</h2>
    <div>
      <label>Hire Start Date</label>
      <input type="date" name="hireStartDate">
    </div>
    <div>
      <label>Hire End Date</label>
      <input type="date" name="hireEndDate">
    </div>
    <div>
      <label>Venue Name</label>
      <input type="text" name="venueName">
    </div>
    <div>
      <label>Venue Address</label>
      <input type="text" name="venueAddress">
    </div>
    <div>
      <label>Eircode</label>
      <input type="text" name="venueEircode">
    </div>
    <div>
      <label>County</label>
      <input type="text" name="venueCounty">
    </div>
    <div>
      <label>Notes</label>
      <textarea name="notes"></textarea>
    </div>

    <button type="submit">Create Enquiry</button>
    <a href="/admin/rental/enquiries">Cancel</a>
  </form>
{% endblock %}

