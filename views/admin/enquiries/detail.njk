{% extends "admin/base/layout.njk" %}
{% from "admin/macros/confirm-modal.njk" import confirmModal %}
{% from "admin/macros/audit-entry.njk" import auditEntry %}

{% block content %}
  <p><a href="/admin/rental/enquiries">← Enquiries</a></p>

  <h1>Enquiry #{{ enquiry.id }} — {{ enquiry.status }}</h1>

  <p>
    <a href="/admin/rental/enquiries/{{ enquiry.id }}/edit">Edit</a>
    {% if enquiry.status != 'ARCHIVED' and enquiry.status != 'CONVERTED' %}
      | <button onclick="document.getElementById('archive-modal').showModal()">Archive</button>
    {% endif %}
    {% if enquiry.status != 'CONVERTED' %}
      | <a href="/admin/rental/bookings/create?enquiryId={{ enquiry.id }}">Create Booking</a>
    {% endif %}
    | <a href="/admin/rental/quotes/create?enquiryId={{ enquiry.id }}">Create Quote</a>
  </p>

  <h2>Customer</h2>
  <p>Name: {{ enquiry.customer.name if enquiry.customer else '—' }}</p>
  <p>Email: {{ enquiry.customer.email if enquiry.customer else '—' }}</p>
  <p>Phone: {{ enquiry.customer.phone if enquiry.customer else '—' }}</p>

  <h2>Event Details</h2>
  <p>Dates:
    {% if enquiry.hireStartDate %}{{ enquiry.hireStartDate | dateFormat('short') }}{% if enquiry.hireEndDate %} – {{ enquiry.hireEndDate | dateFormat('short') }}{% endif %}{% else %}—{% endif %}
  </p>
  <p>Venue: {{ enquiry.venueName or '—' }}</p>
  <p>Address: {{ enquiry.venueAddress or '—' }}</p>
  <p>Eircode: {{ enquiry.venueEircode or '—' }}</p>
  <p>County: {{ enquiry.venueCounty or '—' }}</p>

  <h2>Items Requested</h2>
  <ul>
    {% for item in enquiry.items %}
      <li>{{ item.product.name }} ×{{ item.quantity }}{% if item.customisationNotes %} — {{ item.customisationNotes }}{% endif %}</li>
    {% endfor %}
  </ul>

  {% if enquiry.notes %}
    <h2>Notes</h2>
    <p>{{ enquiry.notes }}</p>
  {% endif %}

  {% if enquiry.bookings.length %}
    <h2>Linked Bookings</h2>
    <ul>
      {% for booking in enquiry.bookings %}
        <li><a href="/admin/rental/bookings/{{ booking.id }}">Booking #{{ booking.id }}</a> — {{ booking.status }}</li>
      {% endfor %}
    </ul>
  {% endif %}

  {% if enquiry.quotes.length %}
    <h2>Quotes</h2>
    <ul>
      {% for quote in enquiry.quotes %}
        <li><a href="/admin/rental/quotes/{{ quote.id }}">{{ quote.reference }}</a> — {{ quote.status }}</li>
      {% endfor %}
    </ul>
  {% endif %}

  <h2>History</h2>
  {% if auditLogs.length %}
    <ul>{% for log in auditLogs %}{{ auditEntry(log) }}{% endfor %}</ul>
  {% else %}
    <p>No history yet.</p>
  {% endif %}

  {{ confirmModal('archive-modal', 'Archive Enquiry', 'Mark this enquiry as archived?', '/admin/rental/enquiries/' + enquiry.id + '/archive', 'POST', 'Archive') }}
{% endblock %}

