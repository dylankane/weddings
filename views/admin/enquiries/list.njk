{% extends "admin/base/layout.njk" %}

{% block content %}
  <h1>Enquiries</h1>
  <a href="/admin/rental/enquiries/create">New Enquiry</a>

  <p>
    Filter:
    <a href="/admin/rental/enquiries">Active</a> |
    <a href="/admin/rental/enquiries?status=NEW">New</a> |
    <a href="/admin/rental/enquiries?status=PENDING">Pending</a> |
    <a href="/admin/rental/enquiries?status=CONVERTED">Converted</a> |
    <a href="/admin/rental/enquiries?status=ARCHIVED">Archived</a>
  </p>

  {% if enquiries.length %}
    <ul>
      {% for enquiry in enquiries %}
        <li>
          <a href="/admin/rental/enquiries/{{ enquiry.id }}">
            #{{ enquiry.id }} — {{ enquiry.customer.name if enquiry.customer else 'Unknown' }}
          </a>
          — {{ enquiry.status }}
          {% if enquiry.hireStartDate %} — {{ enquiry.hireStartDate | dateFormat('short') }}{% endif %}
          {% if enquiry.venueName %} — {{ enquiry.venueName }}{% endif %}
          — {{ enquiry.createdAt | timeAgo }}
        </li>
      {% endfor %}
    </ul>
    <p>Page {{ currentPage }} of {{ totalPages }} ({{ total }} total)</p>
  {% else %}
    <p>No enquiries found.</p>
  {% endif %}
{% endblock %}

