{% extends "admin/base/layout.njk" %}

{% block content %}
  <p><a href="/admin/rental/enquiries/{{ enquiry.id }}">← Enquiry #{{ enquiry.id }}</a></p>
  <h1>Edit Enquiry #{{ enquiry.id }}</h1>

  <form method="POST" action="/admin/rental/enquiries/{{ enquiry.id }}/edit">
    <div>
      <label>Hire Start Date</label>
      <input type="date" name="hireStartDate" value="{{ enquiry.hireStartDate }}">
    </div>
    <div>
      <label>Hire End Date</label>
      <input type="date" name="hireEndDate" value="{{ enquiry.hireEndDate }}">
    </div>
    <div>
      <label>Venue Name</label>
      <input type="text" name="venueName" value="{{ enquiry.venueName }}">
    </div>
    <div>
      <label>Venue Address</label>
      <input type="text" name="venueAddress" value="{{ enquiry.venueAddress }}">
    </div>
    <div>
      <label>Eircode</label>
      <input type="text" name="venueEircode" value="{{ enquiry.venueEircode }}">
    </div>
    <div>
      <label>County</label>
      <input type="text" name="venueCounty" value="{{ enquiry.venueCounty }}">
    </div>
    <div>
      <label>Notes</label>
      <textarea name="notes">{{ enquiry.notes }}</textarea>
    </div>
    <button type="submit">Save</button>
    <a href="/admin/rental/enquiries/{{ enquiry.id }}">Cancel</a>
  </form>
{% endblock %}

