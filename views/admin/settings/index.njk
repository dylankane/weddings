{% extends "admin/base/layout.njk" %}

{% block content %}
  <h1>Settings</h1>

  {% if request.query.saved %}<p>Changes saved.</p>{% endif %}

  <p>
    <a href="/admin/settings?tab=company">Company</a> |
    <a href="/admin/settings?tab=delivery">Delivery Zones</a> |
    <a href="/admin/settings?tab=email-templates">Email Templates</a> |
    <a href="/admin/settings?tab=users">Users</a>
  </p>

  {% if activeTab == 'company' %}
    <h2>Company Settings</h2>
    <form method="POST" action="/admin/settings/company" enctype="multipart/form-data">
      <div>
        <label>Company Name *</label>
        <input type="text" name="companyName" value="{{ companySettings.companyName if companySettings }}" required>
      </div>
      <div>
        <label>Tagline</label>
        <input type="text" name="tagline" value="{{ companySettings.tagline if companySettings }}">
      </div>
      <div>
        <label>Contact Email *</label>
        <input type="email" name="contactEmail" value="{{ companySettings.contactEmail if companySettings }}" required>
      </div>
      <div>
        <label>Contact Phone *</label>
        <input type="tel" name="contactPhone" value="{{ companySettings.contactPhone if companySettings }}" required>
      </div>
      <div>
        <label>Contact Address *</label>
        <textarea name="contactAddress" required>{{ companySettings.contactAddress if companySettings }}</textarea>
      </div>
      <div>
        <label>Meta Title (SEO)</label>
        <input type="text" name="metaTitle" value="{{ companySettings.metaTitle if companySettings }}">
      </div>
      <div>
        <label>Meta Description (SEO)</label>
        <textarea name="metaDescription">{{ companySettings.metaDescription if companySettings }}</textarea>
      </div>
      <div>
        <label>Delivery Info Text (public site)</label>
        <textarea name="deliveryInfoText">{{ companySettings.deliveryInfoText if companySettings }}</textarea>
      </div>
      <div>
        <label>Business Latitude (e.g. 53.3498)</label>
        <input type="number" step="any" name="businessLat" value="{{ companySettings.businessLat if companySettings }}">
      </div>
      <div>
        <label>Business Longitude (e.g. -6.2603)</label>
        <input type="number" step="any" name="businessLng" value="{{ companySettings.businessLng if companySettings }}">
      </div>
      <div>
        <label>Facebook URL</label>
        <input type="url" name="socialFacebook" value="{{ companySettings.socialLinks.facebook if companySettings and companySettings.socialLinks }}">
      </div>
      <div>
        <label>Instagram URL</label>
        <input type="url" name="socialInstagram" value="{{ companySettings.socialLinks.instagram if companySettings and companySettings.socialLinks }}">
      </div>
      <button type="submit">Save Company Settings</button>
    </form>

    <h3>Logos</h3>

    <h4>Light — Small</h4>
    {% if companySettings and companySettings.logoLightSmallUrl %}
      <p><img src="{{ companySettings.logoLightSmallUrl }}" alt="Logo light small"></p>
    {% endif %}
    <form method="POST" action="/admin/settings/company/logo" enctype="multipart/form-data">
      <input type="hidden" name="logoVariant" value="light-small">
      <input type="file" name="file" accept="image/*">
      <button type="submit">Upload</button>
    </form>

    <h4>Light — Large</h4>
    {% if companySettings and companySettings.logoLightLargeUrl %}
      <p><img src="{{ companySettings.logoLightLargeUrl }}" alt="Logo light large"></p>
    {% endif %}
    <form method="POST" action="/admin/settings/company/logo" enctype="multipart/form-data">
      <input type="hidden" name="logoVariant" value="light-large">
      <input type="file" name="file" accept="image/*">
      <button type="submit">Upload</button>
    </form>

    <h4>Dark — Small</h4>
    {% if companySettings and companySettings.logoDarkSmallUrl %}
      <p><img src="{{ companySettings.logoDarkSmallUrl }}" alt="Logo dark small"></p>
    {% endif %}
    <form method="POST" action="/admin/settings/company/logo" enctype="multipart/form-data">
      <input type="hidden" name="logoVariant" value="dark-small">
      <input type="file" name="file" accept="image/*">
      <button type="submit">Upload</button>
    </form>

    <h4>Dark — Large</h4>
    {% if companySettings and companySettings.logoDarkLargeUrl %}
      <p><img src="{{ companySettings.logoDarkLargeUrl }}" alt="Logo dark large"></p>
    {% endif %}
    <form method="POST" action="/admin/settings/company/logo" enctype="multipart/form-data">
      <input type="hidden" name="logoVariant" value="dark-large">
      <input type="file" name="file" accept="image/*">
      <button type="submit">Upload</button>
    </form>

  {% elif activeTab == 'delivery' %}
    <h2>Delivery Zones</h2>
    <a href="/admin/rental/delivery-zones/create">Add Zone</a>

    {% if deliveryZones.length %}
      <ul>
        {% for zone in deliveryZones %}
          <li>
            {{ zone.name }}
            — {{ zone.zoneType }}
            {% if zone.isEnquireOnly %} — Enquire Only{% elif zone.price != null %} — {{ zone.price | currency }}{% else %} — Free{% endif %}
            {% if not zone.isActive %} — INACTIVE{% endif %}
            | <a href="/admin/rental/delivery-zones/{{ zone.id }}/edit">Edit</a>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>No delivery zones configured.</p>
    {% endif %}

  {% elif activeTab == 'email-templates' %}
    <h2>Email Templates</h2>
    {% for template in emailTemplates %}
      <h3>{{ template.name }}</h3>
      <p>{{ template.description }}</p>
      <form method="POST" action="/admin/settings/email-templates/{{ template.id }}">
        <div>
          <label>Subject Line *</label>
          <input type="text" name="subject" value="{{ template.subject }}" required>
        </div>
        <div>
          <label>Active</label>
          <input type="checkbox" name="isActive" {% if template.isActive %}checked{% endif %}>
        </div>
        <button type="submit">Save</button>
      </form>
    {% endfor %}

  {% elif activeTab == 'users' %}
    <h2>Users</h2>
    <a href="/admin/users/create">Add User</a>

    <ul>
      {% for user in users %}
        <li>
          {{ user.displayName }} — {{ user.email }} — {{ user.role }}
          {% if not user.isActive %} — INACTIVE{% endif %}
          {% if user.isActive %}
            | <a href="/admin/users/{{ user.id }}/edit">Edit</a>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}
{% endblock %}

