<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quote {{ quote.reference }}</title>
  <style>
    body { font-family: sans-serif; color: #333; max-width: 800px; margin: 0 auto; padding: 40px; }
    .doc-header { display: flex; justify-content: space-between; margin-bottom: 40px; }
    .doc-title { font-size: 2rem; font-weight: bold; }
    .doc-meta { text-align: right; }
    .doc-ref { font-size: 1.2rem; font-weight: bold; }
    .parties { display: flex; justify-content: space-between; margin-bottom: 32px; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
    th { text-align: left; border-bottom: 2px solid #333; padding: 8px 4px; }
    td { padding: 8px 4px; border-bottom: 1px solid #eee; }
    .totals-row td { font-weight: bold; border-top: 2px solid #333; }
    .doc-footer { margin-top: 40px; font-size: 0.875rem; color: #666; }
  </style>
</head>
<body>
  <div class="doc-header">
    <div>
      {% if companySettings and companySettings.logoUrl %}
        <img src="{{ companySettings.logoUrl }}" alt="{{ companySettings.companyName }}" style="max-height: 60px;">
      {% endif %}
      <div class="doc-title">{{ companySettings.companyName if companySettings else 'Company Name' }}</div>
    </div>
    <div class="doc-meta">
      <div class="doc-ref">QUOTE</div>
      <div>{{ quote.reference }}</div>
      <div>Date: {{ quote.createdAt | dateFormat('short') }}</div>
      <div>Valid Until: {{ quote.expiresAt | dateFormat('short') }}</div>
    </div>
  </div>

  <div class="parties">
    <div>
      <strong>From:</strong><br>
      {{ companySettings.companyName if companySettings }}<br>
      {{ companySettings.contactAddress if companySettings }}<br>
      {{ companySettings.contactEmail if companySettings }}<br>
      {{ companySettings.contactPhone if companySettings }}
    </div>
    <div>
      <strong>To:</strong><br>
      {{ customer.name }}<br>
      {{ customer.email }}<br>
      {% if customer.phone %}{{ customer.phone }}{% endif %}
    </div>
  </div>

  <table>
    <thead>
      <tr>
        <th>Description</th>
        <th>Qty</th>
        <th>Unit Price</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      {% for item in items %}
        <tr>
          <td>{{ item.description }}</td>
          <td>{{ item.quantity }}</td>
          <td>€{{ item.unitPrice }}</td>
          <td>€{{ item.lineTotal }}</td>
        </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr class="totals-row">
        <td colspan="3">Total</td>
        <td>€{{ items | sum(attribute='lineTotal') }}</td>
      </tr>
    </tfoot>
  </table>

  {% if quote.notes %}
    <div style="margin-top: 24px;">
      <strong>Notes:</strong>
      <p>{{ quote.notes }}</p>
    </div>
  {% endif %}

  <div class="doc-footer">
    <p>This quote is valid until {{ quote.expiresAt | dateFormat('short') }}. To accept this quote, please reply to this email or contact us directly.</p>
  </div>
</body>
</html>
