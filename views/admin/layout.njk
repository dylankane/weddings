<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#fbfbfa">
  <title>{% if title %}{{ title }} · {% endif %}Posta Admin</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&family=Fira+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/admin/base.css">
  {% block styles %}{% endblock %}
</head>
<body>

  {% include "shared/sprite.html" %}
  {% include "admin/partials/nav.njk" %}

  <main class="page-content" id="main-content">
    {% block content %}{% endblock %}
  </main>

  <script src="/js/admin/base.js"></script>
  {% block scripts %}{% endblock %}

</body>
</html>
