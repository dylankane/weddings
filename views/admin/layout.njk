<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#fbfbfa">
  <title>{% if title %}{{ title }} · {% endif %}Posta Admin</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/admin/base.css">
  <link rel="stylesheet" href="/css/admin/components.css">
  <link rel="stylesheet" href="/css/admin/navigation.css">
  {% block styles %}{% endblock %}
</head>
<body>

  {% include "shared/sprite.html" %}
  {% include "admin/partials/nav.njk" %}

  {# ─── Select Drawer (mobile form dropdowns) ───────────────────── #}
  <div class="select-drawer" id="select-drawer" aria-modal="true" role="dialog" aria-label="Select option" aria-hidden="true">
    <div class="drawer-backdrop" id="select-drawer-backdrop"></div>
    <div class="drawer-panel">
      <div class="drawer-header">
        <button class="drawer-close" id="select-drawer-close" aria-label="Close">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
        </button>
      </div>
      <div class="select-drawer-list" id="select-drawer-list"></div>
    </div>
  </div>

  <main class="page-content" id="main-content">
    {% block content %}{% endblock %}
  </main>

  <script src="/js/admin/base.js"></script>
  <script src="/js/admin/auto-grow.js"></script>
  {% block scripts %}{% endblock %}

</body>
</html>
