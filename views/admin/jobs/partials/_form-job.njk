{# Job details — included in detail.njk #}

<div class="form-row">
  <div class="form-group">
    <label class="form-label" for="jobStart">Event start date</label>
    <input class="form-input" type="date" id="jobStart" name="jobStart"
      value="{{ job.jobStart | dateFormat('input') if job.jobStart else '' }}">
  </div>
  <div class="form-group">
    <label class="form-label" for="jobEnd">Event end date</label>
    <input class="form-input" type="date" id="jobEnd" name="jobEnd"
      value="{{ job.jobEnd | dateFormat('input') if job.jobEnd else '' }}">
  </div>
</div>

<div class="form-group">
  <label class="form-label" for="jobNotes">Notes</label>
  <textarea class="form-textarea" id="jobNotes" name="notes" rows="1">{{ job.notes or '' }}</textarea>
</div>

{% for item in job.items %}
<div class="form-row form-row--items">
  <input type="hidden" name="items[{{ loop.index0 }}][id]" value="{{ item.id }}">
  <div class="form-group">
    <label class="form-label js-item-label">Product {{ loop.index }}</label>
    <select class="form-select" name="items[{{ loop.index0 }}][productId]" required>
      {% for product in availableProducts %}
      <option value="{{ product.id }}"{{ ' selected' if product.id === item.productId }}>{{ product.name }}</option>
      {% endfor %}
    </select>
  </div>
  <div class="form-group">
    <label class="form-label">Qty</label>
    <input class="form-input" type="number" name="items[{{ loop.index0 }}][quantity]"
      value="{{ item.quantity }}" min="1" required>
  </div>
  <div class="form-group">
    <label class="form-label">Price</label>
    <input class="form-input" type="number" name="items[{{ loop.index0 }}][unitPrice]"
      step="0.01" min="0"
      value="{{ item.unitPrice if item.unitPrice else (item.product.pricePerEvent if item.product.pricePerEvent else '') }}" placeholder="0.00">
  </div>
</div>
{% endfor %}

<script type="application/json" id="js-products-data">{{ availableProducts | dump | safe }}</script>

<button type="button" class="btn" id="js-add-item">
  <svg class="btn-svg" aria-hidden="true"><use href="#icon-plus"/></svg>
  Add product
</button>
