{# Delivery details — included in detail.njk #}
{% from "admin/macros/form-dropdown.njk" import form_dropdown %}

<div class="form-row">
  <div class="form-group">
    <label class="form-label" for="outboundMethod">Outbound method</label>
    {{ form_dropdown(name="outboundMethod", value=job.delivery.outboundMethod if job.delivery else "", id="outboundMethod", options=[
      { value: "STAFF",    label: "Staff delivery" },
      { value: "CUSTOMER", label: "Customer collection" }
    ]) }}
  </div>
  <div class="form-group">
    <label class="form-label" for="returnMethod">Return method</label>
    {{ form_dropdown(name="returnMethod", value=job.delivery.returnMethod if job.delivery else "", id="returnMethod", options=[
      { value: "STAFF",    label: "Staff collection" },
      { value: "CUSTOMER", label: "Customer return" }
    ]) }}
  </div>
</div>

<div class="form-row">
  <div class="form-group">
    <label class="form-label" for="venueName">Venue name</label>
    <input class="form-input" type="text" id="venueName" name="venueName"
      value="{{ job.delivery.venueName if job.delivery and job.delivery.venueName else '' }}">
  </div>
  <div class="form-group">
    <label class="form-label" for="venueCounty">County</label>
    <input class="form-input" type="text" id="venueCounty" name="venueCounty"
      value="{{ job.delivery.venueCounty if job.delivery and job.delivery.venueCounty else '' }}">
  </div>
</div>

<div class="form-group">
  <label class="form-label" for="venueAddress">Venue address</label>
  <input class="form-input" type="text" id="venueAddress" name="venueAddress"
    value="{{ job.delivery.venueAddress if job.delivery and job.delivery.venueAddress else '' }}">
</div>

<div class="form-row">
  <div class="form-group">
    <label class="form-label" for="venueEircode">Eircode</label>
    <input class="form-input" type="text" id="venueEircode" name="venueEircode"
      value="{{ job.delivery.venueEircode if job.delivery and job.delivery.venueEircode else '' }}"
      style="text-transform: uppercase;">
  </div>
  <div class="form-group">
    <label class="form-label" for="outboundAt">Delivery date &amp; time</label>
    <input class="form-input" type="datetime-local" id="outboundAt" name="outboundAt"
      value="{{ job.delivery.outboundAt | dateFormat('datetime-input') if job.delivery and job.delivery.outboundAt else '' }}">
  </div>
</div>

<div class="form-row">
  <div class="form-group">
    <label class="form-label" for="returnAt">Collection date &amp; time</label>
    <input class="form-input" type="datetime-local" id="returnAt" name="returnAt"
      value="{{ job.delivery.returnAt | dateFormat('datetime-input') if job.delivery and job.delivery.returnAt else '' }}">
  </div>
  <div class="form-group">
    <label class="form-label" for="deliveryNotes">Delivery notes</label>
    <input class="form-input" type="text" id="deliveryNotes" name="deliveryNotes"
      value="{{ job.delivery.notes if job.delivery and job.delivery.notes else '' }}">
  </div>
</div>
