{% extends "admin/layout.njk" %}
{% from "admin/macros/breadcrumb.njk" import breadcrumb %}
{% from "admin/macros/status-badge.njk" import status_badge %}

{% block styles %}
<link rel="stylesheet" href="/css/admin/jobs.css">
{% endblock %}

{% block content %}

{# ─── Page Bar ────────────────────────────────────────────────── #}

<div class="page-bar">
  {{ breadcrumb([{ label: 'Home', url: '/admin' }, { label: 'Jobs' }]) }}
  <div class="page-bar-right">
    <a href="/admin/jobs/new" class="btn btn-pill--accent fw-heavy" aria-label="New job" title="New job">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-add"/></svg>
      <span>New</span>
    </a>
  </div>
</div>

<h1 class="page-greeting">All Jobs</h1>

{# ─── Table ───────────────────────────────────────────────────── #}

<div class="table-filter-bar">
  <input type="text" class="search-input" placeholder="Search jobs by customer, month, invoice, job number…" title="Search jobs by customer, month, invoice or job number" aria-label="Search jobs">
  <div class="form-dropdown" data-dropdown>
    <input type="hidden" class="js-filter-status" value="">
    <button type="button" class="btn js-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false">
      <span class="form-dropdown-value">All Jobs</span>
      <svg class="btn-left-extra" aria-hidden="true"><use href="#icon-chevron-down"/></svg>
    </button>
    <ul class="form-dropdown-list form-dropdown-list--wide" role="listbox">
      <li class="form-dropdown-option is-selected" role="option" aria-selected="true"  tabindex="-1" data-value="">All Jobs</li>
      <li class="form-dropdown-option" role="option" aria-selected="false" tabindex="-1" data-value="ENQUIRY">Enquiry</li>
      <li class="form-dropdown-option" role="option" aria-selected="false" tabindex="-1" data-value="CONFIRMED">Confirmed</li>
      <li class="form-dropdown-option" role="option" aria-selected="false" tabindex="-1" data-value="COMPLETED">Completed</li>
      <li class="form-dropdown-option" role="option" aria-selected="false" tabindex="-1" data-value="CANCELLED">Cancelled</li>
    </ul>
  </div>
</div>

<div class="data-card">
  {% if jobs | length %}
  <div class="table-wrap">
    <table class="data-table" aria-label="Jobs">
      <thead>
        <tr>
          <th scope="col">#</th>
          <th scope="col">Customer</th>
          <th scope="col">Event Date</th>
          <th scope="col">Status</th>
          <th scope="col">Delivery</th>
          <th scope="col">Invoice</th>
        </tr>
      </thead>
      <tbody>
        {% for job in jobs %}
        <tr class="data-row" data-href="/admin/jobs/{{ job.id }}" data-status="{{ job.status }}">
          <td>{{ job.id }}</td>
          <td>{{ job.customer.name }}</td>
          <td>
            {{ job.jobStart | dateFormat('short') if job.jobStart else '—' }}
          </td>
          <td>{{ status_badge(job.status, 'status-badge--plain') }}</td>
          <td>
            {% if job.delivery %}
              {{ 'Staff' if job.delivery.outboundMethod === 'STAFF' else 'Customer' }}
            {% else %}
              <span style="color: var(--text-3)">—</span>
            {% endif %}
          </td>
          <td>
            {% if job.invoice %}
              <span class="inv inv--{{ job.invoice.status | lower }}">
                {{ job.invoice.status | capitalize }}
              </span>
            {% else %}
              <span class="inv inv--none">—</span>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% else %}
  <div class="empty">
    No jobs{{ ' with status ' + activeStatus | lower if activeStatus else '' }}
  </div>
  {% endif %}
</div>

{% endblock %}
