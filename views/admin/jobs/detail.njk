{% extends "admin/layout.njk" %}
{% from "admin/macros/breadcrumb.njk" import breadcrumb %}
{% from "admin/macros/status-badge.njk" import status_badge %}
{% from "admin/macros/form-dropdown.njk" import form_dropdown %}

{% block styles %}
<link rel="stylesheet" href="/css/admin/jobs.css">
{% endblock %}

{% block scripts %}
<script src="/js/admin/delivery.js"></script>
<script src="/js/admin/items.js"></script>
<script src="/js/admin/pricing.js"></script>
{% endblock %}

{% block content %}

{# ─── Page Bar ────────────────────────────────────────────────── #}

<div class="page-bar">
  {{ breadcrumb([
    { label: 'Home', url: '/admin' },
    { label: 'Jobs', url: '/admin/jobs' },
    { label: job.customer.name }
  ]) }}
  <nav class="page-bar-right" aria-label="Navigate jobs">
    {% if prevJob %}
      <a href="/admin/jobs/{{ prevJob.id }}" class="btn" title="Previous job" aria-label="Previous job">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-chevron-left"/></svg>
      </a>
    {% else %}
      <span class="btn btn--disabled" aria-hidden="true">
        <svg class="btn-svg"><use href="#icon-chevron-left"/></svg>
      </span>
    {% endif %}
    {% if nextJob %}
      <a href="/admin/jobs/{{ nextJob.id }}" class="btn" title="Next job" aria-label="Next job">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-chevron-right"/></svg>
      </a>
    {% else %}
      <span class="btn btn--disabled" aria-hidden="true">
        <svg class="btn-svg"><use href="#icon-chevron-right"/></svg>
      </span>
    {% endif %}
  </nav>
</div>


{# ─── Header ──────────────────────────────────────────────────── #}

<div class="job-header">
  <span class="job-ref">Job #{{ job.id }}</span>
  <div class="job-title-row">
    <h1 class="job-name">{{ job.customer.name }}</h1>
    <form action="/admin/jobs/{{ job.id }}/status" method="POST">
      <div class="form-dropdown" data-dropdown data-autosubmit>
        <input type="hidden" name="status" value="{{ job.status }}">
        <button type="button" class="btn js-dropdown-trigger" aria-haspopup="listbox" aria-expanded="false">
          <span class="status-badge status-badge--{{ job.status | lower }}">
            <span class="dot dot--{{ job.status | lower }}"></span>
            <span class="form-dropdown-value">
              {%- if job.status === 'ENQUIRY' %}Enquiry
              {%- elif job.status === 'CONFIRMED' %}Confirmed
              {%- elif job.status === 'COMPLETED' %}Completed
              {%- elif job.status === 'CANCELLED' %}Cancelled
              {%- endif -%}
            </span>
          </span>
          <svg class="btn-left-extra" aria-hidden="true"><use href="#icon-chevron-down"/></svg>
        </button>
        <ul class="form-dropdown-list" role="listbox">
          <li class="form-dropdown-option{{ ' is-selected' if job.status === 'ENQUIRY' }}" role="option" aria-selected="{{ 'true' if job.status === 'ENQUIRY' else 'false' }}" tabindex="-1" data-value="ENQUIRY">Enquiry</li>
          <li class="form-dropdown-option{{ ' is-selected' if job.status === 'CONFIRMED' }}" role="option" aria-selected="{{ 'true' if job.status === 'CONFIRMED' else 'false' }}" tabindex="-1" data-value="CONFIRMED">Confirmed</li>
          <li class="form-dropdown-option{{ ' is-selected' if job.status === 'COMPLETED' }}" role="option" aria-selected="{{ 'true' if job.status === 'COMPLETED' else 'false' }}" tabindex="-1" data-value="COMPLETED">Completed</li>
          <li class="form-dropdown-option{{ ' is-selected' if job.status === 'CANCELLED' }}" role="option" aria-selected="{{ 'true' if job.status === 'CANCELLED' else 'false' }}" tabindex="-1" data-value="CANCELLED">Cancelled</li>
        </ul>
      </div>
    </form>
  </div>

  <div class="job-recap">
    {% if job.jobStart %}
      <div class="recap-item">{{ job.jobStart | dateFormat('short') }}{% if job.jobEnd %} → {{ job.jobEnd | dateFormat('short') }}{% endif %}</div>
    {% endif %}
    {% if job.delivery and job.delivery.venueName %}
      <div class="recap-item">{{ job.delivery.venueName }}</div>
    {% endif %}
    {% if job.delivery and job.delivery.venueCounty %}
      <div class="recap-item">{{ job.delivery.venueCounty }}</div>
    {% endif %}
    {% if job.pricing and job.pricing.totalCost %}
      <div class="recap-item">{{ job.pricing.totalCost | currency }}</div>
    {% endif %}
  </div>
</div>


{# ─── Sections ────────────────────────────────────────────────── #}

<div class="content-container">

  {# ── Customer Details ── #}
  <section class="form-section" aria-labelledby="section-customer-title">
    <div class="form-section-head">
      <h2 class="form-section-title" id="section-customer-title">Customer Details</h2>
      <label class="toggle-switch" aria-label="Edit customer details">
        <input type="checkbox" class="js-section-toggle">
        <span class="toggle-track"></span>
        <span class="toggle-label">Edit</span>
      </label>
    </div>

    <div class="form-section-view">
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Name</span>
          <span class="field-value">{{ job.customer.name }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">Email</span>
          <span class="field-value">{{ job.customer.email }}</span>
        </div>
      </div>
      <div class="form-group">
        <span class="field-label">Phone</span>
        <span class="field-value{{ ' field-value--empty' if not job.customer.phone }}">{{ job.customer.phone or '—' }}</span>
      </div>
    </div>

    <form class="form-section-form" action="/admin/jobs/{{ job.id }}/customer" method="POST">
      {% include "admin/jobs/partials/_form-customer.njk" %}
      <div class="section-actions">
        <button type="button" class="btn btn-cancel js-section-cancel">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
          Cancel
        </button>
        <button type="submit" class="btn btn-save">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-save"/></svg>
          Save
        </button>
      </div>
    </form>
  </section>

  {# ── Job Details ── #}
  <section class="form-section" aria-labelledby="section-job-title">
    <div class="form-section-head">
      <h2 class="form-section-title" id="section-job-title">Job Details</h2>
      <label class="toggle-switch" aria-label="Edit job details">
        <input type="checkbox" class="js-section-toggle">
        <span class="toggle-track"></span>
        <span class="toggle-label">Edit</span>
      </label>
    </div>

    <div class="form-section-view">
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Source</span>
          <span class="field-value">{{ 'Website form' if job.source === 'CUSTOMER_FORM' else 'Manager created' }}</span>
        </div>
        <div class="form-group"></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Event start date</span>
          <span class="field-value{{ ' field-value--empty' if not job.jobStart }}">{{ job.jobStart | dateFormat('short') if job.jobStart else '—' }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">Event end date</span>
          <span class="field-value{{ ' field-value--empty' if not job.jobEnd }}">{{ job.jobEnd | dateFormat('short') if job.jobEnd else '—' }}</span>
        </div>
      </div>
      <div class="form-group">
        <span class="field-label">Notes</span>
        <span class="field-value{{ ' field-value--empty' if not job.notes }}">{{ job.notes or '—' }}</span>
      </div>
      {% if job.items and job.items.length %}
        {% for item in job.items %}
        <div class="form-row form-row--items">
          <div class="form-group">
            <span class="field-label">Product {{ loop.index }}</span>
            <span class="field-value">{{ item.product.name }}</span>
          </div>
          <div class="form-group">
            <span class="field-label">Qty</span>
            <span class="field-value">{{ item.quantity }}</span>
          </div>
          <div class="form-group">
            <span class="field-label">Price</span>
            <span class="field-value{{ ' field-value--empty' if not (item.unitPrice or item.product.pricePerEvent) }}">{{ (item.unitPrice or item.product.pricePerEvent) | currency if (item.unitPrice or item.product.pricePerEvent) else '—' }}</span>
          </div>
        </div>
        {% endfor %}
      {% else %}
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Products</span>
          <span class="field-value field-value--empty">—</span>
        </div>
      </div>
      {% endif %}
    </div>

    <form class="form-section-form" action="/admin/jobs/{{ job.id }}/job" method="POST">
      {% include "admin/jobs/partials/_form-job.njk" %}
      <div class="section-actions">
        <button type="button" class="btn btn-cancel js-section-cancel">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
          Cancel
        </button>
        <button type="submit" class="btn btn-save">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-save"/></svg>
          Save
        </button>
      </div>
    </form>
  </section>

  {# ── Delivery ── #}
  <section class="form-section" id="section-delivery" aria-labelledby="section-delivery-title">
    <div class="form-section-head">
      <h2 class="form-section-title" id="section-delivery-title">Delivery</h2>
      <label class="toggle-switch" aria-label="Edit delivery">
        <input type="checkbox" class="js-section-toggle">
        <span class="toggle-track"></span>
        <span class="toggle-label">Edit</span>
      </label>
    </div>

    <div class="form-section-view">
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Outbound method</span>
          <span class="field-value{{ ' field-value--empty' if not job.delivery }}">
            {%- if job.delivery -%}
              {{ 'Staff delivery' if job.delivery.outboundMethod === 'STAFF' else 'Customer collection' }}
            {%- else -%}—{%- endif -%}
          </span>
        </div>
        <div class="form-group">
          <span class="field-label">Return method</span>
          <span class="field-value{{ ' field-value--empty' if not job.delivery }}">
            {%- if job.delivery -%}
              {{ 'Staff collection' if job.delivery.returnMethod === 'STAFF' else 'Customer return' }}
            {%- else -%}—{%- endif -%}
          </span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Delivery date &amp; time</span>
          <span class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.outboundAt) }}">{{ job.delivery.outboundAt | dateFormat('datetime') if job.delivery and job.delivery.outboundAt else '—' }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">Collection date &amp; time</span>
          <span class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.returnAt) }}">{{ job.delivery.returnAt | dateFormat('datetime') if job.delivery and job.delivery.returnAt else '—' }}</span>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Venue name</span>
          <span id="view-venue-name" class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.venueName) }}">{{ job.delivery.venueName if job.delivery and job.delivery.venueName else '—' }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">County</span>
          <span id="view-venue-county" class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.venueCounty) }}">{{ job.delivery.venueCounty if job.delivery and job.delivery.venueCounty else '—' }}</span>
        </div>
      </div>
      <div class="form-group">
        <span class="field-label">Venue address</span>
        <span id="view-venue-address" class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.venueAddress) }}">{{ job.delivery.venueAddress if job.delivery and job.delivery.venueAddress else '—' }}</span>
      </div>
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Eircode</span>
          <span id="view-venue-eircode" class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.venueEircode) }}">{{ job.delivery.venueEircode if job.delivery and job.delivery.venueEircode else '—' }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">Delivery notes</span>
          <span class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.notes) }}">{{ job.delivery.notes if job.delivery and job.delivery.notes else '—' }}</span>
        </div>
      </div>

    </div>

    <form class="form-section-form" action="/admin/jobs/{{ job.id }}/delivery" method="POST">
      {% include "admin/jobs/partials/_form-delivery.njk" %}
      <div class="section-actions">
        <button type="button" class="btn btn-cancel js-section-cancel">
                <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
                Cancel
              </button>
        <button type="submit" class="btn btn-save">
                <svg class="btn-svg" aria-hidden="true"><use href="#icon-save"/></svg>
                Save
              </button>
      </div>
    </form>
  </section>

  {# ── Delivery Calculator ── #}
  <section class="form-section" aria-labelledby="section-calculator-title" data-job-id="{{ job.id }}">
    <div class="form-section-head">
      <h2 class="form-section-title" id="section-calculator-title">Delivery Calculator</h2>
      <div class="form-dropdown" id="venue-search-dropdown">
        <button type="button" class="btn" id="js-find-venue">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-search"/></svg>
          <span id="js-find-venue-label">Find venue</span>
        </button>
        <ul class="form-dropdown-list form-dropdown-list--wide" id="venue-results-list" role="listbox"></ul>
      </div>
    </div>
    {% set hasCalc = job.delivery and job.delivery.distanceKm %}
    <div class="form-section-view">
      <div class="form-row">
        <div class="form-group">
          <span class="field-label">Result</span>
          <span class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.calculatorResult) }}" id="venue-result-display">{{ job.delivery.calculatorResult if job.delivery and job.delivery.calculatorResult else '—' }}</span>
        </div>
        <div class="form-group">
          <button type="button" class="field-label field-label--copy" id="js-copy-maps-url" aria-label="Copy maps URL">
            Maps URL
            <svg class="field-label-icon" aria-hidden="true"><use href="#icon-copy"/></svg>
          </button>
          <a class="field-value{{ ' field-value--empty' if not (job.delivery and job.delivery.mapsUrl) }}" id="venue-maps-display" target="_blank"{% if job.delivery and job.delivery.mapsUrl %} href="{{ job.delivery.mapsUrl }}"{% endif %}>{{ job.delivery.mapsUrl if job.delivery and job.delivery.mapsUrl else '—' }}</a>
        </div>
      </div>
      <div class="form-row js-calc-row"{% if not hasCalc %} hidden{% endif %}>
        <div class="form-group">
          <span class="field-label">Distance</span>
          <span class="field-value js-calc-distance">{{ (job.delivery.distanceKm | string + ' km') if hasCalc else '—' }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">Drive time</span>
          <span class="field-value js-calc-duration">
            {%- if hasCalc and job.delivery.durationMins -%}
              {%- if job.delivery.durationMins < 60 -%}{{ job.delivery.durationMins }} mins
              {%- else -%}{{ (job.delivery.durationMins / 60) | int }}h {% if job.delivery.durationMins % 60 %}{{ job.delivery.durationMins % 60 }}min{% endif %}
              {%- endif -%}
            {%- else -%}—{%- endif -%}
          </span>
        </div>
      </div>
      <div class="form-row js-calc-row"{% if not hasCalc %} hidden{% endif %}>
        <div class="form-group">
          <span class="field-label">Tier</span>
          <span class="field-value js-calc-tier">{{ job.pricing.deliveryZone.name if job.pricing and job.pricing.deliveryZone else '—' }}</span>
        </div>
        <div class="form-group">
          <span class="field-label">Suggested price</span>
          <span class="field-value js-calc-price">{{ job.delivery.suggestedPrice | currency if hasCalc and job.delivery.suggestedPrice else '—' }}</span>
        </div>
      </div>
      <div class="section-actions section-actions--hidden" id="js-calc-save-row">
        <button type="button" class="btn btn-save" id="js-save-calculator">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-save"/></svg>
          Save to job
        </button>
      </div>
    </div>
  </section>

  {# ── Pricing ── #}
  <section class="form-section" aria-labelledby="section-pricing-title">
    <div class="form-section-head">
      <h2 class="form-section-title" id="section-pricing-title">Pricing</h2>
      <label class="toggle-switch" aria-label="Edit pricing">
        <input type="checkbox" class="js-section-toggle">
        <span class="toggle-track"></span>
        <span class="toggle-label">Edit</span>
      </label>
    </div>

    <div class="data-card">
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Description</th>
              <th class="td--center">Qty</th>
              <th class="td--center">Unit Price</th>
              <th class="td--center">Subtotal</th>
            </tr>
          </thead>
          <tbody>
            {% for item in job.items %}
            {% set unitPrice = item.unitPrice or item.product.pricePerEvent or 0 %}
            {% set subtotal = unitPrice * item.quantity %}
            <tr class="tr--static">
              <td>{{ item.product.name }}</td>
              <td class="td--center">{{ item.quantity }}</td>
              <td class="td--center">{{ unitPrice | currency if unitPrice else '—' }}</td>
              <td class="js-pricing-subtotal td--center" data-value="{{ subtotal }}">{{ subtotal | currency }}</td>
            </tr>
            {% endfor %}
            {% if job.delivery and job.delivery.suggestedPrice %}
            <tr id="js-pricing-delivery-row" class="tr--static">
              <td>Delivery</td>
              <td class="td--center">1</td>
              <td class="td--center">{{ job.delivery.suggestedPrice | currency }}</td>
              <td class="js-pricing-subtotal td--center" data-value="{{ job.delivery.suggestedPrice }}">{{ job.delivery.suggestedPrice | currency }}</td>
            </tr>
            {% endif %}
            <tr id="js-pricing-spacer-row" class="tr--static">
              <td></td>
              <td></td>
              <td></td>
              <td></td>
            </tr>
            <tr class="tr--static tr--total">
              <td></td>
              <td></td>
              <td class="td--center">Total</td>
              <td id="js-pricing-total" class="td--center"></td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <form class="form-section-form" action="/admin/jobs/{{ job.id }}/pricing" method="POST">
      <div class="data-card">
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Description</th>
                <th class="td--center">Qty</th>
                <th class="td--center">Unit Price</th>
                <th class="td--center">Subtotal</th>
              </tr>
            </thead>
            <tbody id="js-pricing-edit-body" data-next-row="{{ job.items | length + (1 if (job.delivery and job.delivery.suggestedPrice) else 0) }}">
              {% for item in job.items %}
              {% set unitPrice = item.unitPrice or item.product.pricePerEvent or 0 %}
              {% set subtotal = unitPrice * item.quantity %}
              <tr class="tr--static">
                <td><input class="form-input" type="text" name="rows[{{ loop.index0 }}][description]" value="{{ item.product.name }}"></td>
                <td class="td--center"><input class="form-input js-row-qty" type="number" name="rows[{{ loop.index0 }}][qty]" value="{{ item.quantity }}" min="1"></td>
                <td class="td--center"><input class="form-input js-row-price" type="number" name="rows[{{ loop.index0 }}][unitPrice]" value="{{ unitPrice }}" step="0.01" min="0"></td>
                <td class="js-edit-subtotal td--center" data-value="{{ subtotal }}">{{ subtotal | currency }}</td>
              </tr>
              {% endfor %}
              {% if job.delivery and job.delivery.suggestedPrice %}
              {% set deliveryRowIndex = job.items | length %}
              <tr class="tr--static">
                <td><input class="form-input" type="text" name="rows[{{ deliveryRowIndex }}][description]" value="Delivery"></td>
                <td class="td--center"><input class="form-input js-row-qty" type="number" name="rows[{{ deliveryRowIndex }}][qty]" value="1" min="1"></td>
                <td class="td--center"><input class="form-input js-row-price" type="number" name="rows[{{ deliveryRowIndex }}][unitPrice]" value="{{ job.delivery.suggestedPrice }}" step="0.01" min="0"></td>
                <td class="js-edit-subtotal td--center" data-value="{{ job.delivery.suggestedPrice }}">{{ job.delivery.suggestedPrice | currency }}</td>
              </tr>
              {% endif %}
              <tr id="js-edit-spacer-row" class="tr--static">
                <td></td><td></td><td></td><td></td>
              </tr>
              <tr class="tr--static tr--total">
                <td></td><td></td>
                <td class="td--center">Total</td>
                <td id="js-edit-total" class="td--center"></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="section-actions">
        <button type="button" class="btn" id="js-pricing-add-row" style="margin-right: auto;">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-plus"/></svg>
          Add row
        </button>
        <button type="button" class="btn btn-cancel js-section-cancel">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
          Cancel
        </button>
        <button type="submit" class="btn btn-save">
          <svg class="btn-svg" aria-hidden="true"><use href="#icon-save"/></svg>
          Save
        </button>
      </div>
    </form>

  </section>

</div>

{% endblock %}
