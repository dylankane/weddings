{# ─── Sidebar (desktop) ───────────────────────────────────────── #}

<aside class="sidebar" role="navigation" aria-label="Main navigation">

  <div class="sidebar-header">
    <a href="/admin" class="sidebar-header-link">POSTA</a>
    <div class="sidebar-header-actions">
      <a href="/admin/jobs/new" class="btn btn-pill--accent fw-heavy" aria-label="New job" title="New job">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-add"/></svg>
        <span>New</span>
      </a>
      <button class="btn" id="sidebar-search-btn" aria-label="Search" title="Search" aria-expanded="false" aria-controls="sidebar-search">
        <svg class="btn-svg btn-svg--lg" aria-hidden="true"><use href="#icon-search"/></svg>
      </button>
    </div>
  </div>

  <div class="sidebar-search" id="sidebar-search">
    <input type="text" class="search-input" placeholder="Search jobs by customer, month, invoice, job number…" title="Search jobs by customer, month, invoice or job number" aria-label="Search jobs">
    <div class="search-results" id="sidebar-search-results">
      <p class="search-empty">Start typing to search…</p>
    </div>
  </div>

  <nav class="sidebar-nav">
    <a href="/admin" class="btn btn-nav {{ 'is-active' if currentPage === 'dashboard' }}">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-dashboard"/></svg>
      Home
    </a>
    <a href="/admin/jobs" class="btn btn-nav {{ 'is-active' if currentPage === 'jobs' }}">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-bookings"/></svg>
      Jobs
      {% if enquiryCount %}
        <span class="btn-left-extra">{{ enquiryCount }}</span>
      {% endif %}
    </a>
    <a href="/admin/products" class="btn btn-nav {{ 'is-active' if currentPage === 'products' }}">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-products"/></svg>
      Products
    </a>
    <a href="/admin/documents" class="btn btn-nav {{ 'is-active' if currentPage === 'documents' }}">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-pdf"/></svg>
      Documents
    </a>
    <a href="/admin/settings" class="btn btn-nav {{ 'is-active' if currentPage === 'settings' }}">
      <svg class="btn-svg" aria-hidden="true"><use href="#icon-settings"/></svg>
      Settings
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      {{ sessionUser.displayName if sessionUser else '—' }}
    </div>
  </div>

</aside>

{# ─── Bottom Nav (mobile) ──────────────────────────────────────── #}

<nav class="bottom-nav" role="navigation" aria-label="Main navigation">

  <a href="/admin" class="btn btn-col btn--muted btn--no-hover {{ 'is-active' if currentPage === 'dashboard' }}" aria-label="Home">
    <svg class="btn-svg btn-svg--lg" aria-hidden="true"><use href="#icon-dashboard"/></svg>
    <span>Home</span>
  </a>

  <a href="/admin/jobs" class="btn btn-col btn--muted btn--no-hover {{ 'is-active' if currentPage === 'jobs' }}" aria-label="Jobs">
    <svg class="btn-svg btn-svg--lg" aria-hidden="true"><use href="#icon-bookings"/></svg>
    <span>Jobs</span>
  </a>

  <a href="/admin/jobs/new" class="btn btn-col btn-col--accent btn--no-hover" aria-label="New job">
    <svg class="btn-svg btn-svg--lg" aria-hidden="true"><use href="#icon-add"/></svg>
    <span>New</span>
  </a>

  <button
    class="btn btn-col btn--muted btn--no-hover"
    id="mobile-search-btn"
    aria-label="Search"
    aria-expanded="false"
    aria-controls="search-overlay"
  >
    <svg class="btn-svg btn-svg--lg" aria-hidden="true"><use href="#icon-search"/></svg>
    <span>Search</span>
  </button>

  <button
    class="btn btn-col btn--muted btn--no-hover"
    id="bn-more-btn"
    aria-label="More"
    aria-expanded="false"
    aria-controls="nav-drawer"
  >
    <svg class="btn-svg btn-svg--lg" aria-hidden="true"><use href="#icon-more"/></svg>
    <span>More</span>
  </button>

</nav>

{# ─── Mobile Drawer ────────────────────────────────────────────── #}

<div class="nav-drawer" id="nav-drawer" aria-hidden="true" aria-label="More navigation">

  <div class="drawer-backdrop" id="drawer-backdrop"></div>

  <div class="drawer-panel" role="dialog">

    <div class="drawer-header">
      <button class="drawer-close" id="drawer-close" aria-label="Close menu">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
      </button>
    </div>

    <nav class="drawer-nav">
      <a href="/admin/products" class="btn btn--lg">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-products"/></svg>
        Products
      </a>
      <a href="/admin/documents" class="btn btn--lg">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-pdf"/></svg>
        Documents
      </a>
      <a href="/admin/settings" class="btn btn--lg">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-settings"/></svg>
        Settings
      </a>
    </nav>

    <div class="drawer-divider"></div>

    <div class="drawer-footer">
      {{ sessionUser.displayName if sessionUser else '—' }}
    </div>

  </div>
</div>

{# ─── Mobile Search ────────────────────────────────────────────── #}

<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-overlay-bg" id="search-overlay-bg"></div>
  <div class="search-overlay-panel">
    <div class="search-overlay-head">
      <input type="text" class="search-input" placeholder="Search jobs by customer, month, invoice, job number…" title="Search jobs by customer, month, invoice or job number" aria-label="Search jobs">
      <button class="btn btn--muted" id="search-overlay-close" aria-label="Close search">
        <svg class="btn-svg" aria-hidden="true"><use href="#icon-close"/></svg>
      </button>
    </div>
    <div class="search-results" id="mobile-search-results">
      <p class="search-empty">Start typing to search…</p>
    </div>
  </div>
</div>
