{# ─── Sidebar (desktop) ───────────────────────────────────────── #}

<aside class="sidebar" role="navigation" aria-label="Main navigation">

  <div class="sidebar-brand">
    <a href="/admin" class="sidebar-brand-link">POSTA</a>
  </div>

  <nav class="sidebar-nav">
    <a href="/admin" class="nav-item {{ 'is-active' if currentPage === 'dashboard' }}">
      <span class="nav-item-inner">
        <svg class="nav-icon" aria-hidden="true"><use href="#icon-dashboard"/></svg>
        Dashboard
      </span>
    </a>
    <a href="/admin/jobs" class="nav-item {{ 'is-active' if currentPage === 'jobs' }}">
      <span class="nav-item-inner">
        <svg class="nav-icon" aria-hidden="true"><use href="#icon-bookings"/></svg>
        Jobs
      </span>
      {% if enquiryCount %}
        <span class="nav-badge">{{ enquiryCount }}</span>
      {% endif %}
    </a>
    <a href="/admin/products" class="nav-item {{ 'is-active' if currentPage === 'products' }}">
      <span class="nav-item-inner">
        <svg class="nav-icon" aria-hidden="true"><use href="#icon-products"/></svg>
        Products
      </span>
    </a>
    <a href="/admin/settings" class="nav-item {{ 'is-active' if currentPage === 'settings' }}">
      <span class="nav-item-inner">
        <svg class="nav-icon" aria-hidden="true"><use href="#icon-settings"/></svg>
        Settings
      </span>
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      {{ sessionUser.displayName if sessionUser else '—' }}
    </div>
  </div>

</aside>

{# ─── Bottom Nav (mobile) ──────────────────────────────────────── #}

<nav class="bottom-nav" role="navigation" aria-label="Main navigation">

  <a href="/admin" class="bn-item {{ 'is-active' if currentPage === 'dashboard' }}" aria-label="Dashboard">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
      <polyline points="9 22 9 12 15 12 15 22"/>
    </svg>
    <span>Dashboard</span>
  </a>

  <a href="/admin/jobs" class="bn-item {{ 'is-active' if currentPage === 'jobs' }}" aria-label="Jobs">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect width="20" height="14" x="2" y="7" rx="2"/>
      <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
    </svg>
    <span>Jobs</span>
  </a>

  <a href="/admin/jobs/new" class="bn-item bn-item--new" aria-label="New job">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 5v14M5 12h14"/>
    </svg>
    <span>New</span>
  </a>

  <button
    class="bn-item"
    id="bn-more-btn"
    aria-label="More"
    aria-expanded="false"
    aria-controls="nav-drawer"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="5" cy="12" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/>
    </svg>
    <span>More</span>
  </button>

</nav>

{# ─── Mobile Drawer ────────────────────────────────────────────── #}

<div class="nav-drawer" id="nav-drawer" aria-hidden="true" aria-label="More navigation">

  <div class="drawer-backdrop" id="drawer-backdrop"></div>

  <div class="drawer-panel" role="dialog">

    <div class="drawer-header">
      <button class="drawer-close" id="drawer-close" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <nav class="drawer-nav">
      <a href="/admin/products" class="drawer-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
          <polyline points="3.29 7 12 12 20.71 7"/><line x1="12" x2="12" y1="22" y2="12"/>
        </svg>
        Products
      </a>
      <a href="/admin/settings" class="drawer-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/>
          <circle cx="12" cy="12" r="3"/>
        </svg>
        Settings
      </a>
    </nav>

    <div class="drawer-divider"></div>

    <div class="drawer-footer">
      {{ sessionUser.displayName if sessionUser else '—' }}
    </div>

  </div>
</div>
