{% extends "public/layout.njk" %}

{% block title %}The Collection — {{ companySettings.companyName or 'posadh' }}{% endblock %}

{% block meta %}
<meta name="description" content="Browse cast iron post boxes available to hire for your wedding day. Check availability for your date and enquire directly.">
{% endblock %}

{% block styles %}
<link rel="stylesheet" href="/css/public/collection.css">
{% endblock %}

{% block content %}

<div class="col-wrapper">

  <section class="col-header">
    <div class="blob blob--col-header fade-fast" aria-hidden="true"></div>
    <div class="col-header-body fade-slow">
      <p class="col-kicker">Products &ensp;&middot;&ensp; {{ companySettings.companyName or 'posadh' }}</p>
      <h1 class="col-title">The Collection</h1>
      <p class="col-subtitle">Cast iron post boxes, available to hire for your wedding day. Each piece is original, lockable, and delivered to your venue.</p>
    </div>
  </section>

  <div class="avail-strip" id="avail-strip" role="search" aria-label="Check availability for a date">
    <div class="avail-strip-inner">
      <label for="avail-date" class="avail-strip-label">Checking for</label>
      <input type="date" id="avail-date" class="avail-strip-input" aria-label="Your wedding date">
      <button type="button" class="avail-strip-clear" id="avail-clear" aria-label="Clear date" hidden>Clear</button>
      <span class="avail-strip-status" id="avail-status" aria-live="polite" aria-atomic="true"></span>
    </div>
  </div>

  {% if products.length %}

  <div class="col-products" id="col-products">

    {% for product in products %}

    {%- set galleryUrls -%}{%- for img in product.images -%}{{ img.url }}{%- if not loop.last -%}|{%- endif -%}{%- endfor -%}{%- endset -%}
    {%- set galleryAlts -%}{%- for img in product.images -%}{{ img.altText or '' }}{%- if not loop.last -%}|{%- endif -%}{%- endfor -%}{%- endset -%}

    <article
      class="col-item reveal-left"
      data-product-id="{{ product.id }}"
      aria-label="{{ product.name }}"
    >

      <div class="col-item-image">
        <img
          src="{{ product.images[0].url if product.images[0] else '/images/public/produt-fallback.jpeg' }}"
          alt="{{ product.images[0].altText if product.images[0] else product.name }}"
          loading="{% if loop.first %}eager{% else %}lazy{% endif %}"
          {% if loop.first %}fetchpriority="high"{% endif %}
        >
        <div class="col-item-overlay" aria-hidden="true"></div>
        <span class="col-item-unavail-label" aria-hidden="true">Unavailable</span>
        <button
          class="lb-trigger"
          data-images="{{ galleryUrls or '/images/public/produt-fallback.jpeg' }}"
          data-alts="{{ galleryAlts }}"
          data-name="{{ product.name }}"
          aria-label="View photos of {{ product.name }}"
          type="button"
        >
          <svg class="lb-trigger-icon" aria-hidden="true"><use href="#icon-expand"/></svg>
        </button>
      </div>

      <div class="col-item-body">
        <div class="col-item-content">
          <h2 class="col-item-name">{{ product.name }}</h2>
          <p class="col-item-desc">{{ product.description }}</p>

          <a href="/enquiry" class="btn btn-text-light btn-sm">
            Enquire about this piece
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

    </article>

    {% endfor %}

  </div>

  {% else %}

  <div class="col-empty">
    <p class="col-empty-text">The collection is being updated. Please check back soon or <a href="/enquiry">get in touch directly</a>.</p>
  </div>

  {% endif %}

  <section class="col-cta">
    <div class="blob blob--col-cta" aria-hidden="true"></div>
    <div class="col-cta-content">
      <h2 class="col-title col-title-dark">Ready for your day?</h2>
      <p class="col-subtitle subtitle-light">Tell us your date and venue. We reply within 24 hours.</p>
      <a href="/enquiry" class="btn btn-outline-dark btn-sm">
        Make an enquiry
      </a>
    </div>
  </section>

</div>

<div class="lb" id="lb" role="dialog" aria-modal="true" aria-label="Image gallery" hidden>
  <button class="lb-backdrop" id="lb-backdrop" aria-label="Close gallery" tabindex="-1"></button>
  <button class="lb-close" id="lb-close" aria-label="Close gallery">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6L6 18M6 6l12 12"/></svg>
  </button>
  <div class="lb-inner">
    <button class="lb-nav lb-prev" id="lb-prev" aria-label="Previous image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <div class="lb-media">
      <img class="lb-img" id="lb-img" src="" alt="">
      <div class="lb-dots" id="lb-dots" aria-hidden="true"></div>
    </div>
    <button class="lb-nav lb-next" id="lb-next" aria-label="Next image">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/public/availability.js" defer></script>
<script src="/js/public/lightbox.js" defer></script>
{% endblock %}
