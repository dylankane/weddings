<footer class="footer" role="contentinfo">
  <div class="footer-grid">
    <div class="footer-col">
      <a href="/" class="footer-brand">Posta</a>
      <p class="footer-tagline">{{ companySettings.tagline if companySettings and companySettings.tagline else 'Cast iron post box hire for Irish weddings.' }}</p>
    </div>
    <div class="footer-col">
      <span class="footer-col-label">Explore</span>
      <ul class="footer-links" role="list">
        <li><a href="/collection">Collection</a></li>
        <li><a href="/delivery">Delivery</a></li>
        <li><a href="/about">About</a></li>
        <li><a href="/enquiry">Enquire</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <span class="footer-col-label">Contact</span>
      {% if companySettings %}
      <div class="footer-contact-list">
        {% if companySettings.contactEmail %}
        <div class="footer-contact-row">
          <a class="footer-contact-item" href="mailto:{{ companySettings.contactEmail }}">
            <svg class="footer-contact-icon" aria-hidden="true"><use href="#icon-email"/></svg>
            <span class="footer-contact-value">{{ companySettings.contactEmail }}</span>
          </a>
          <button class="footer-copy-btn" type="button" aria-label="Copy email address" data-copy="{{ companySettings.contactEmail }}">
            <svg class="footer-copy-icon" aria-hidden="true"><use href="#icon-copy"/></svg>
          </button>
        </div>
        {% endif %}
        {% if companySettings.contactPhone %}
        <div class="footer-contact-row">
          <a class="footer-contact-item" href="tel:{{ companySettings.contactPhone }}">
            <svg class="footer-contact-icon" aria-hidden="true"><use href="#icon-phone"/></svg>
            <span class="footer-contact-value">{{ companySettings.contactPhone }}</span>
          </a>
          <button class="footer-copy-btn" type="button" aria-label="Copy phone number" data-copy="{{ companySettings.contactPhone }}">
            <svg class="footer-copy-icon" aria-hidden="true"><use href="#icon-copy"/></svg>
          </button>
        </div>
        {% endif %}
        {% if companySettings.contactPhone %}
        <a class="footer-contact-item" href="https://wa.me/{{ companySettings.contactPhone | whatsapp }}" target="_blank" rel="noopener noreferrer">
          <svg class="footer-contact-icon" aria-hidden="true"><use href="#icon-whatsapp"/></svg>
          <span class="footer-contact-value">WhatsApp</span>
        </a>
        {% endif %}
      </div>
      {% endif %}
    </div>
  </div>
  <div class="footer-base">
    <span>&copy; {{ currentYear }} {{ companySettings.companyName if companySettings and companySettings.companyName else 'Posta' }}. All rights reserved.</span>
    <a href="/legal">Terms &amp; Conditions</a>
  </div>
</footer>
